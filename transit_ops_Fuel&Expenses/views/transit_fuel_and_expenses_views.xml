<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ================= LIST VIEW ================= -->
        <record id="view_transit_expense_list" model="ir.ui.view">
            <field name="name">transit.expense.list</field>
            <field name="model">transit.expense</field>
            <field name="arch" type="xml">
                <list string="Fuel &amp; Expenses" decoration-info="expense_type == 'fuel'">
                    <field name="date"/>
                    <field name="vehicle_id"/>
                    <field name="driver_id" optional="show"/>
                    <field name="trip_id" optional="hide"/>
                    <field name="expense_type"/>
                    <field name="fuel_quantity" optional="show" sum="Total Fuel (L)"/>
                    <field name="fuel_cost" optional="show" sum="Total Fuel Cost"/>
                    <field name="expense_amount" sum="Total Amount"/>
                    <field name="month" optional="hide"/>
                    <field name="currency_id" invisible="1"/>
                </list>
            </field>
        </record>

        <!-- ================= FORM VIEW ================= -->
        <record id="view_transit_expense_form" model="ir.ui.view">
            <field name="name">transit.expense.form</field>
            <field name="model">transit.expense</field>
            <field name="arch" type="xml">
                <form string="Fuel / Expense Entry">
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="vehicle_id" placeholder="Select Vehicle..." options="{'no_create': True}"/>
                            </h1>
                        </div>
                        <group>
                            <group string="Expense Details">
                                <field name="expense_type"/>
                                <field name="date"/>
                                <field name="trip_id" options="{'no_create': True}"/>
                                <field name="driver_id" options="{'no_create': True}"/>
                            </group>
                            <group string="Amount">
                                <field name="currency_id" invisible="1"/>
                                <field name="expense_amount"/>
                                <field name="odometer_reading"/>
                            </group>
                        </group>
                        <group string="Fuel Details" invisible="expense_type != 'fuel'">
                            <group>
                                <field name="fuel_quantity"
                                       required="expense_type == 'fuel'"/>
                                <field name="fuel_cost"
                                       required="expense_type == 'fuel'"/>
                            </group>
                            <group>
                                <field name="month" readonly="1"/>
                            </group>
                        </group>
                        <group string="Receipt &amp; Remarks">
                            <field name="receipt" filename="receipt_filename"/>
                            <field name="receipt_filename" invisible="1"/>
                            <field name="remarks" nolabel="1" colspan="2" placeholder="Additional notes..."/>
                        </group>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- ================= SEARCH VIEW ================= -->
        <record id="view_transit_expense_search" model="ir.ui.view">
            <field name="name">transit.expense.search</field>
            <field name="model">transit.expense</field>
            <field name="arch" type="xml">
                <search string="Search Fuel &amp; Expenses">
                    <field name="vehicle_id"/>
                    <field name="driver_id"/>
                    <field name="trip_id"/>
                    <field name="expense_type"/>
                    <field name="remarks"/>
                    <filter string="Fuel" name="filter_fuel" domain="[('expense_type', '=', 'fuel')]"/>
                    <filter string="Toll" name="filter_toll" domain="[('expense_type', '=', 'toll')]"/>
                    <filter string="Parking" name="filter_parking" domain="[('expense_type', '=', 'parking')]"/>
                    <filter string="Repair" name="filter_repair" domain="[('expense_type', '=', 'repair')]"/>
                    <separator/>
                    <filter string="This Month" name="filter_this_month"
                            domain="[('date', '&gt;=', context_today().strftime('%Y-%m-01'))]"/>
                    <filter string="Date" name="filter_date" date="date"/>
                    <separator/>
                    <filter string="Has Receipt" name="filter_has_receipt" domain="[('receipt', '!=', False)]"/>
                    <group expand="1" string="Group By">
                        <filter string="Vehicle" name="group_vehicle" context="{'group_by': 'vehicle_id'}"/>
                        <filter string="Driver" name="group_driver" context="{'group_by': 'driver_id'}"/>
                        <filter string="Expense Type" name="group_type" context="{'group_by': 'expense_type'}"/>
                        <filter string="Month" name="group_month" context="{'group_by': 'month'}"/>
                        <filter string="Year" name="group_year" context="{'group_by': 'year'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- ================= PIVOT VIEW (Monthly Totals) ================= -->
        <record id="view_transit_expense_pivot" model="ir.ui.view">
            <field name="name">transit.expense.pivot</field>
            <field name="model">transit.expense</field>
            <field name="arch" type="xml">
                <pivot string="Expense Analysis" display_quantity="true">
                    <field name="month" type="row"/>
                    <field name="expense_type" type="col"/>
                    <field name="expense_amount" type="measure"/>
                    <field name="fuel_cost" type="measure"/>
                    <field name="fuel_quantity" type="measure"/>
                </pivot>
            </field>
        </record>

        <!-- ================= GRAPH VIEW ================= -->
        <record id="view_transit_expense_graph" model="ir.ui.view">
            <field name="name">transit.expense.graph</field>
            <field name="model">transit.expense</field>
            <field name="arch" type="xml">
                <graph string="Expense Trend" type="bar">
                    <field name="month" type="row"/>
                    <field name="expense_amount" type="measure"/>
                </graph>
            </field>
        </record>

        <!-- ================= ACTIONS ================= -->
        <record id="action_transit_expense" model="ir.actions.act_window">
            <field name="name">Fuel &amp; Expenses</field>
            <field name="res_model">transit.expense</field>
            <field name="view_mode">list,form,pivot,graph</field>
            <field name="search_view_id" ref="view_transit_expense_search"/>
            <field name="context">{'search_default_filter_this_month': 0}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Log your first fuel or expense entry
                </p>
                <p>
                    Track fuel fill-ups, tolls, parking, repairs and other vehicle expenses.
                    Use the Pivot / Graph views to review monthly totals per vehicle.
                </p>
            </field>
        </record>

        <record id="action_transit_expense_monthly_summary" model="ir.actions.act_window">
            <field name="name">Monthly Expense Summary</field>
            <field name="res_model">transit.expense</field>
            <field name="view_mode">pivot,graph,list</field>
            <field name="search_view_id" ref="view_transit_expense_search"/>
            <field name="context">{'search_default_group_month': 1, 'pivot_measures': ['expense_amount', 'fuel_cost', 'fuel_quantity']}</field>
        </record>

        <record id="action_transit_expense_fuel_only" model="ir.actions.act_window">
            <field name="name">Fuel Logs</field>
            <field name="res_model">transit.expense</field>
            <field name="view_mode">list,form,graph</field>
            <field name="search_view_id" ref="view_transit_expense_search"/>
            <field name="domain">[('expense_type', '=', 'fuel')]</field>
            <field name="context">{'default_expense_type': 'fuel'}</field>
        </record>

    </data>
</odoo>
