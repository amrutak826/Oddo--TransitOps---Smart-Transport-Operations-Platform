<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ==================================================================
         List View
    =================================================================== -->
    <record id="view_transit_vehicle_list" model="ir.ui.view">
        <field name="name">transit.vehicle.list</field>
        <field name="model">transit.vehicle</field>
        <field name="arch" type="xml">
            <list string="Vehicles" decoration-muted="status == 'retired'"
                  decoration-info="status == 'active'"
                  decoration-warning="status == 'maintenance'"
                  sample="1">
                <field name="name"/>
                <field name="fleet_number"/>
                <field name="vehicle_type"/>
                <field name="brand"/>
                <field name="model"/>
                <field name="fuel_type"/>
                <field name="current_driver_id"/>
                <field name="odometer" widget="float" sum="Total Odometer"/>
                <field name="document_alert_level" widget="badge"
                       decoration-success="document_alert_level == 'none'"
                       decoration-warning="document_alert_level == 'warning'"
                       decoration-danger="document_alert_level == 'danger'"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'active'"
                       decoration-info="status == 'on_trip'"
                       decoration-warning="status == 'maintenance'"
                       decoration-muted="status in ('inactive', 'retired')"/>
            </list>
        </field>
    </record>

    <!-- ==================================================================
         Form View
    =================================================================== -->
    <record id="view_transit_vehicle_form" model="ir.ui.view">
        <field name="name">transit.vehicle.form</field>
        <field name="model">transit.vehicle</field>
        <field name="arch" type="xml">
            <form string="Vehicle">
                <header>
                    <button name="action_set_active" type="object" string="Set Active"
                            class="oe_highlight" invisible="status == 'active'"/>
                    <button name="action_set_maintenance" type="object" string="Send to Maintenance"
                            invisible="status == 'maintenance'"/>
                    <button name="action_set_inactive" type="object" string="Deactivate"
                            invisible="status == 'inactive'"/>
                    <button name="action_set_retired" type="object" string="Retire"
                            confirm="Are you sure you want to retire this vehicle?"
                            invisible="status == 'retired'"/>
                    <field name="status" widget="statusbar"
                           statusbar_visible="active,on_trip,maintenance,inactive,retired"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_trips" type="object"
                                class="oe_stat_button" icon="fa-road">
                            <field name="trip_count" widget="statinfo" string="Trips"/>
                        </button>
                        <button name="action_view_maintenance" type="object"
                                class="oe_stat_button" icon="fa-wrench">
                            <field name="maintenance_count" widget="statinfo" string="Maintenance"/>
                        </button>
                    </div>
                    <field name="image" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="e.g. KA-01-AB-1234"/>
                        </h1>
                        <field name="document_alert_level" invisible="1"/>
                        <div class="alert alert-danger" role="alert"
                             invisible="document_alert_level != 'danger'">
                            <strong>Document Expired:</strong>
                            <field name="next_document_to_expire" readonly="1" nolabel="1"/>
                            expired on
                            <field name="next_document_expiry_date" readonly="1" nolabel="1"/>
                        </div>
                        <div class="alert alert-warning" role="alert"
                             invisible="document_alert_level != 'warning'">
                            <strong>Document Expiring Soon:</strong>
                            <field name="next_document_to_expire" readonly="1" nolabel="1"/>
                            expires on
                            <field name="next_document_expiry_date" readonly="1" nolabel="1"/>
                        </div>
                    </div>
                    <group>
                        <group string="Identification">
                            <field name="fleet_number"/>
                            <field name="vehicle_type"/>
                            <field name="brand"/>
                            <field name="model"/>
                            <field name="year"/>
                            <field name="color"/>
                        </group>
                        <group string="Technical">
                            <field name="chassis_number"/>
                            <field name="engine_number"/>
                            <field name="fuel_type"/>
                            <field name="seating_capacity"/>
                            <field name="odometer"/>
                        </group>
                    </group>
                    <group>
                        <group string="Assignment">
                            <field name="current_driver_id"/>
                            <field name="purchase_date"/>
                        </group>
                        <group string="Documents &amp; Compliance">
                            <field name="insurance_expiry"/>
                            <field name="fitness_expiry"/>
                            <field name="permit_expiry"/>
                            <field name="puc_expiry"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes" name="notes">
                            <field name="notes" placeholder="Additional notes about this vehicle..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ==================================================================
         Kanban View
    =================================================================== -->
    <record id="view_transit_vehicle_kanban" model="ir.ui.view">
        <field name="name">transit.vehicle.kanban</field>
        <field name="model">transit.vehicle</field>
        <field name="arch" type="xml">
            <kanban class="o_transit_kanban" sample="1">
                <field name="name"/>
                <field name="status"/>
                <field name="document_alert_level"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click o_transit_vehicle_card">
                            <div class="d-flex justify-content-between align-items-start">
                                <div class="o_kanban_image me-2">
                                    <img t-att-src="kanban_image('transit.vehicle', 'image', record.id.raw_value)"
                                         alt="Vehicle" class="o_kanban_image_fit_cover" width="48" height="48"/>
                                </div>
                                <div class="flex-grow-1">
                                    <strong><field name="name"/></strong>
                                    <div class="text-muted">
                                        <field name="fleet_number"/>
                                        <span> · </span>
                                        <field name="vehicle_type"/>
                                    </div>
                                    <div class="text-muted">
                                        <field name="current_driver_id"/>
                                    </div>
                                </div>
                            </div>
                            <div class="mt-2 d-flex justify-content-between align-items-center">
                                <field name="status" widget="badge"
                                       decoration-success="status == 'active'"
                                       decoration-info="status == 'on_trip'"
                                       decoration-warning="status == 'maintenance'"
                                       decoration-muted="status in ('inactive', 'retired')"/>
                                <field name="document_alert_level" widget="badge"
                                       decoration-success="document_alert_level == 'none'"
                                       decoration-warning="document_alert_level == 'warning'"
                                       decoration-danger="document_alert_level == 'danger'"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ==================================================================
         Search View
    =================================================================== -->
    <record id="view_transit_vehicle_search" model="ir.ui.view">
        <field name="name">transit.vehicle.search</field>
        <field name="model">transit.vehicle</field>
        <field name="arch" type="xml">
            <search string="Search Vehicles">
                <field name="name" string="Vehicle"
                       filter_domain="['|', '|', ('name', 'ilike', self), ('fleet_number', 'ilike', self), ('brand', 'ilike', self)]"/>
                <field name="current_driver_id"/>
                <field name="vehicle_type"/>
                <filter string="Active" name="filter_active" domain="[('status', '=', 'active')]"/>
                <filter string="On Trip" name="filter_on_trip" domain="[('status', '=', 'on_trip')]"/>
                <filter string="In Maintenance" name="filter_maintenance" domain="[('status', '=', 'maintenance')]"/>
                <filter string="Documents Expiring/Expired" name="filter_doc_alert"
                        domain="[('document_alert_level', 'in', ('warning', 'danger'))]"/>
                <separator/>
                <filter string="Archived" name="filter_archived" domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_status" context="{'group_by': 'status'}"/>
                    <filter string="Vehicle Type" name="group_type" context="{'group_by': 'vehicle_type'}"/>
                    <filter string="Fuel Type" name="group_fuel" context="{'group_by': 'fuel_type'}"/>
                    <filter string="Current Driver" name="group_driver" context="{'group_by': 'current_driver_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ==================================================================
         Action
    =================================================================== -->
    <record id="action_transit_vehicle" model="ir.actions.act_window">
        <field name="name">Vehicles</field>
        <field name="res_model">transit.vehicle</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_transit_vehicle_search"/>
        <field name="context">{'search_default_filter_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Register your first vehicle
            </p>
            <p>
                Track registration, documents, assigned drivers and status for your entire fleet.
            </p>
        </field>
    </record>

</odoo>
