<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================= List View ================= -->
    <record id="view_transit_driver_list" model="ir.ui.view">
        <field name="name">transit.driver.list</field>
        <field name="model">transit.driver</field>
        <field name="arch" type="xml">
            <list string="Drivers" decoration-danger="license_status=='expired'"
                  decoration-warning="license_status=='expiring_soon'"
                  decoration-muted="state=='inactive'">
                <field name="sequence_code"/>
                <field name="name"/>
                <field name="license_number"/>
                <field name="license_type"/>
                <field name="license_expiry"/>
                <field name="phone"/>
                <field name="experience_years" sum="Total Experience"/>
                <field name="license_status" widget="badge"
                       decoration-success="license_status=='valid'"
                       decoration-warning="license_status=='expiring_soon'"
                       decoration-danger="license_status=='expired'"/>
                <field name="state" widget="badge"
                       decoration-success="state=='available'"
                       decoration-info="state=='on_trip'"
                       decoration-warning="state=='on_leave'"
                       decoration-muted="state=='inactive'"/>
            </list>
        </field>
    </record>

    <!-- ================= Form View ================= -->
    <record id="view_transit_driver_form" model="ir.ui.view">
        <field name="name">transit.driver.form</field>
        <field name="model">transit.driver</field>
        <field name="arch" type="xml">
            <form string="Driver">
                <header>
                    <button name="action_view_trips" type="object" string="View Trips" class="btn-secondary"/>
                    <field name="state" widget="statusbar" statusbar_visible="available,on_trip,on_leave,inactive"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_trips" type="object" class="oe_stat_button" icon="fa-road">
                            <field name="trip_count" widget="statinfo" string="Trips"/>
                        </button>
                        <button class="oe_stat_button" icon="fa-truck" type="object" name="action_view_trips" invisible="vehicle_count == 0">
                            <field name="vehicle_count" widget="statinfo" string="Vehicles"/>
                        </button>
                    </div>
                    <field name="image" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Driver full name"/></h1>
                        <h3><field name="sequence_code" readonly="1"/></h3>
                    </div>
                    <group>
                        <group string="License Details">
                            <field name="license_number"/>
                            <field name="license_type"/>
                            <field name="license_expiry"/>
                            <field name="license_status" widget="badge"
                                   decoration-success="license_status=='valid'"
                                   decoration-warning="license_status=='expiring_soon'"
                                   decoration-danger="license_status=='expired'"/>
                        </group>
                        <group string="Contact">
                            <field name="phone"/>
                            <field name="mobile"/>
                            <field name="email" widget="email"/>
                        </group>
                    </group>
                    <group>
                        <group string="Employment">
                            <field name="date_joined"/>
                            <field name="experience_years"/>
                            <field name="user_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group string="Address">
                            <field name="address" nolabel="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes">
                            <field name="notes" placeholder="Internal notes about this driver..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ================= Search View ================= -->
    <record id="view_transit_driver_search" model="ir.ui.view">
        <field name="name">transit.driver.search</field>
        <field name="model">transit.driver</field>
        <field name="arch" type="xml">
            <search string="Search Drivers">
                <field name="name" string="Driver" filter_domain="['|', ('name', 'ilike', self), ('license_number', 'ilike', self)]"/>
                <field name="license_type"/>
                <filter string="Available" name="filter_available" domain="[('state', '=', 'available')]"/>
                <filter string="On Trip" name="filter_on_trip" domain="[('state', '=', 'on_trip')]"/>
                <filter string="On Leave" name="filter_on_leave" domain="[('state', '=', 'on_leave')]"/>
                <filter string="Inactive" name="filter_inactive" domain="[('state', '=', 'inactive')]"/>
                <separator/>
                <filter string="License Expiring Soon" name="filter_license_expiring" domain="[('license_status', '=', 'expiring_soon')]"/>
                <filter string="License Expired" name="filter_license_expired" domain="[('license_status', '=', 'expired')]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="License Type" name="group_license_type" context="{'group_by': 'license_type'}"/>
                    <filter string="License Status" name="group_license_status" context="{'group_by': 'license_status'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ================= Action ================= -->
    <record id="action_transit_driver" model="ir.actions.act_window">
        <field name="name">Drivers</field>
        <field name="res_model">transit.driver</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_transit_driver_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add your first driver
            </p>
            <p>
                Manage driver profiles, licenses and trip assignments.
            </p>
        </field>
    </record>

</odoo>
