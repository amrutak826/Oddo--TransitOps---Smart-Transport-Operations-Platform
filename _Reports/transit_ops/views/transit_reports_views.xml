        <field name="arch" type="xml">
            <pivot string="Trip Report">
                <field name="driver_id" type="row"/>
                <field name="state" type="col"/>
                <field name="distance_km" type="measure"/>
                <field name="passenger_count" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_transit_trip_graph" model="ir.ui.view">
        <field name="name">transit.trip.graph</field>
        <field name="model">transit.trip</field>
        <field name="arch" type="xml">
            <graph string="Trip Report" type="line">
                <field name="scheduled_start" type="row" interval="day"/>
                <field name="distance_km" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="action_transit_trip_report" model="ir.actions.act_window">
        <field name="name">Trip Report</field>
