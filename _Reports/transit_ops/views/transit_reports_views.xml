<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- =====================================================
         FLEET REPORT (transit.vehicle)
         ===================================================== -->
    <record id="view_transit_vehicle_pivot" model="ir.ui.view">
        <field name="name">transit.vehicle.pivot</field>
        <field name="model">transit.vehicle</field>
        <field name="arch" type="xml">
            <pivot string="Fleet Report">
                <field name="vehicle_type" type="row"/>
                <field name="state" type="col"/>
                <field name="odometer" type="measure"/>
                <field name="total_fuel_cost" type="measure"/>
                <field name="total_maintenance_cost" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_transit_vehicle_graph" model="ir.ui.view">
        <field name="name">transit.vehicle.graph</field>
        <field name="model">transit.vehicle</field>
        <field name="arch" type="xml">
            <graph string="Fleet Report" type="bar">
                <field name="vehicle_type" type="row"/>
                <field name="total_fuel_cost" type="measure"/>
                <field name="total_maintenance_cost" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="action_transit_fleet_report" model="ir.actions.act_window">
        <field name="name">Fleet Report</field>
        <field name="res_model">transit.vehicle</field>
        <field name="view_mode">pivot,graph,list,form</field>
        <field name="search_view_id" ref="view_transit_vehicle_search"/>
        <field name="context">{'search_default_group_type': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No vehicle data to analyze yet
            </p>
        </field>
    </record>

    <!-- =====================================================
         DRIVER REPORT (transit.driver)
         ===================================================== -->
    <record id="view_transit_driver_pivot" model="ir.ui.view">
        <field name="name">transit.driver.pivot</field>
        <field name="model">transit.driver</field>
        <field name="arch" type="xml">
            <pivot string="Driver Report">
                <field name="license_type" type="row"/>
                <field name="state" type="col"/>
                <field name="experience_years" type="measure"/>
                <field name="trip_count" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_transit_driver_graph" model="ir.ui.view">
        <field name="name">transit.driver.graph</field>
        <field name="model">transit.driver</field>
        <field name="arch" type="xml">
            <graph string="Driver Report" type="bar">
                <field name="name" type="row"/>
                <field name="trip_count" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="action_transit_driver_report" model="ir.actions.act_window">
        <field name="name">Driver Report</field>
        <field name="res_model">transit.driver</field>
        <field name="view_mode">pivot,graph,list,form</field>
        <field name="search_view_id" ref="view_transit_driver_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No driver data to analyze yet
            </p>
        </field>
    </record>

