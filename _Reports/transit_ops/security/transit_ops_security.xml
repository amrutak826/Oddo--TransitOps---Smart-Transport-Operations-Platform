<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- ================= Security Category ================= -->
        <record id="module_category_transit_ops" model="ir.module.category">
            <field name="name">TransitOps</field>
            <field name="description">Smart Transport Operations Platform access levels</field>
            <field name="sequence">15</field>
        </record>

        <!-- ================= Security Groups ================= -->

        <!-- Viewer: read-only access to everything -->
        <record id="group_transit_viewer" model="res.groups">
            <field name="name">Viewer</field>
            <field name="category_id" ref="module_category_transit_ops"/>
            <field name="comment">Read-only access to fleet, drivers, trips, maintenance and reports.</field>
        </record>

        <!-- Driver: portal-like operational access to own trips and vehicle -->
        <record id="group_transit_driver" model="res.groups">
            <field name="name">Driver</field>
            <field name="category_id" ref="module_category_transit_ops"/>
            <field name="implied_ids" eval="[(4, ref('group_transit_viewer'))]"/>
            <field name="comment">Drivers can view and update their own assigned trips, log fuel and expenses.</field>
        </record>

        <!-- Dispatcher: can create/assign trips, manage day to day operations -->
        <record id="group_transit_dispatcher" model="res.groups">
            <field name="name">Dispatcher</field>
            <field name="category_id" ref="module_category_transit_ops"/>
            <field name="implied_ids" eval="[(4, ref('group_transit_viewer'))]"/>
            <field name="comment">Dispatchers manage trip planning, assignment and tracking.</field>
        </record>

        <!-- Fleet Manager: full access, including vehicles, maintenance, security config -->
        <record id="group_transit_fleet_manager" model="res.groups">
            <field name="name">Fleet Manager</field>
            <field name="category_id" ref="module_category_transit_ops"/>
            <field name="implied_ids" eval="[(4, ref('group_transit_dispatcher')), (4, ref('group_transit_driver'))]"/>
            <field name="comment">Full administrative access to the TransitOps application.</field>
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
        </record>

        <!-- ================= Record Rules ================= -->

        <!-- Drivers can only see their own trips -->
        <record id="rule_trip_driver_own" model="ir.rule">
            <field name="name">Driver: Own Trips Only</field>
            <field name="model_id" ref="model_transit_trip"/>
            <field name="domain_force">[('driver_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_transit_driver'))]"/>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">0</field>
            <field name="perm_unlink">0</field>
        </record>

        <!-- Dispatchers and Fleet Managers see all trips -->
        <record id="rule_trip_dispatcher_all" model="ir.rule">
            <field name="name">Dispatcher: All Trips</field>
            <field name="model_id" ref="model_transit_trip"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_transit_dispatcher')), (4, ref('group_transit_fleet_manager'))]"/>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
            <field name="perm_unlink">1</field>
        </record>

        <!-- Drivers can only see/edit their own fuel logs and expenses -->
        <record id="rule_fuel_log_driver_own" model="ir.rule">
            <field name="name">Driver: Own Fuel Logs Only</field>
            <field name="model_id" ref="model_transit_fuel_log"/>
            <field name="domain_force">[('driver_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_transit_driver'))]"/>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
            <field name="perm_unlink">0</field>
        </record>

        <record id="rule_fuel_log_dispatcher_all" model="ir.rule">
            <field name="name">Dispatcher: All Fuel Logs</field>
            <field name="model_id" ref="model_transit_fuel_log"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_transit_dispatcher')), (4, ref('group_transit_fleet_manager'))]"/>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
            <field name="perm_unlink">1</field>
        </record>

        <record id="rule_expense_driver_own" model="ir.rule">
            <field name="name">Driver: Own Expenses Only</field>
            <field name="model_id" ref="model_transit_expense"/>
            <field name="domain_force">[('driver_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_transit_driver'))]"/>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
            <field name="perm_unlink">0</field>
        </record>

        <record id="rule_expense_dispatcher_all" model="ir.rule">
            <field name="name">Dispatcher: All Expenses</field>
            <field name="model_id" ref="model_transit_expense"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_transit_dispatcher')), (4, ref('group_transit_fleet_manager'))]"/>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
            <field name="perm_unlink">1</field>
        </record>

    </data>
</odoo>
