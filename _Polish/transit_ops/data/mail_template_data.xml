<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <record id="mail_template_vehicle_document_expiry" model="mail.template">
        <field name="name">TransitOps: Vehicle Document Expiry</field>
        <field name="model_id" ref="model_transit_vehicle"/>
        <field name="subject">⚠ Document Expiry Alert - {{ object.display_name }}</field>
        <field name="email_from">{{ (object.company_id.email or user.email) }}</field>
        <field name="email_to">{{ object.default_driver_id.email or '' }}</field>
        <field name="auto_delete" eval="True"/>
        <field name="body_html" type="html">
<div style="margin:0;padding:0;font-family:Arial,Helvetica,sans-serif;background-color:#1e1e1e;color:#f2f2f2;">
    <table width="100%" cellpadding="0" cellspacing="0" style="background-color:#1e1e1e;padding:24px 0;">
        <tr>
            <td align="center">
                <table width="600" cellpadding="0" cellspacing="0" style="background-color:#2a2a2a;border-radius:8px;overflow:hidden;">
                    <tr>
                        <td style="background-color:#ff7a1a;padding:16px 24px;">
                            <span style="font-size:20px;font-weight:bold;color:#1e1e1e;">TransitOps Alert</span>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding:24px;">
                            <p style="font-size:16px;margin:0 0 12px 0;">
                                Hello,
                            </p>
                            <p style="font-size:14px;line-height:1.6;margin:0 0 16px 0;">
                                One or more compliance documents for vehicle
                                <strong style="color:#ff7a1a;" t-out="object.display_name"/>
                                are expired or will expire soon. Please arrange renewal at the earliest.
                            </p>
                            <table width="100%" cellpadding="8" cellspacing="0" style="border:1px solid #3a3a3a;border-radius:4px;font-size:13px;">
                                <tr style="background-color:#333333;">
                                    <td style="color:#ff7a1a;font-weight:bold;">Document</td>
                                    <td style="color:#ff7a1a;font-weight:bold;">Expiry Date</td>
                                </tr>
                                <tr>
                                    <td>Registration (RC)</td>
                                    <td t-out="object.registration_expiry_date or '-'"/>
                                </tr>
                                <tr>
                                    <td>Insurance</td>
                                    <td t-out="object.insurance_expiry_date or '-'"/>
                                </tr>
                                <tr>
                                    <td>Pollution Certificate</td>
                                    <td t-out="object.puc_expiry_date or '-'"/>
                                </tr>
                                <tr>
                                    <td>Permit</td>
                                    <td t-out="object.permit_expiry_date or '-'"/>
                                </tr>
                            </table>
                            <p style="font-size:12px;color:#999999;margin-top:20px;">
                                This is an automated message from TransitOps - Smart Transport Operations Platform.
                            </p>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</div>
        </field>
    </record>

</odoo>
