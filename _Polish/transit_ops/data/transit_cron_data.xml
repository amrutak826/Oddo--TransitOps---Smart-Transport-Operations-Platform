<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <record id="ir_cron_check_vehicle_documents" model="ir.cron">
        <field name="name">TransitOps: Check Vehicle Document Expiry</field>
        <field name="model_id" ref="model_transit_vehicle"/>
        <field name="state">code</field>
        <field name="code">model._cron_check_vehicle_documents()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
    </record>

    <record id="ir_cron_check_driver_licenses" model="ir.cron">
        <field name="name">TransitOps: Check Driver License Expiry</field>
        <field name="model_id" ref="model_transit_driver"/>
        <field name="state">code</field>
        <field name="code">model._cron_check_driver_licenses()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
    </record>

</odoo>
