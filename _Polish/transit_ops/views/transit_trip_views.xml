<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_transit_trip_list" model="ir.ui.view">
        <field name="name">transit.trip.list</field>
        <field name="model">transit.trip</field>
        <field name="arch" type="xml">
            <list string="Trips" decoration-muted="state == 'cancelled'"
                  decoration-info="state == 'in_progress'"
                  decoration-success="state == 'completed'">
                <field name="name"/>
                <field name="vehicle_id"/>
                <field name="driver_id"/>
                <field name="origin"/>
                <field name="destination"/>
                <field name="scheduled_departure"/>
                <field name="scheduled_arrival"/>
                <field name="distance_km" sum="Total Distance"/>
                <field name="priority" widget="priority"/>
                <field name="state" widget="badge"
                       decoration-muted="state in ('draft', 'cancelled')"
                       decoration-info="state == 'scheduled'"
                       decoration-warning="state == 'in_progress'"
                       decoration-success="state == 'completed'"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_transit_trip_form" model="ir.ui.view">
        <field name="name">transit.trip.form</field>
        <field name="model">transit.trip</field>
        <field name="arch" type="xml">
            <form string="Trip">
                <header>
                    <button name="action_confirm" string="Confirm" type="object"
                            class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_start" string="Start Trip" type="object"
                            class="oe_highlight" invisible="state != 'scheduled'"/>
                    <button name="action_complete" string="Complete Trip" type="object"
                            class="oe_highlight" invisible="state != 'in_progress'"/>
                    <button name="action_cancel" string="Cancel" type="object"
                            invisible="state in ('completed', 'cancelled')"/>
                    <button name="action_reset_draft" string="Reset to Draft" type="object"
                            invisible="state not in ('scheduled', 'cancelled')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,scheduled,in_progress,completed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Assignment">
                            <field name="vehicle_id" options="{'no_create': True}"/>
                            <field name="driver_id" options="{'no_create': True}"/>
                            <field name="priority" widget="priority"/>
                        </group>
                        <group string="Route">
                            <field name="origin"/>
                            <field name="destination"/>
                            <field name="distance_km"/>
                            <field name="passenger_count"/>
                        </group>
                    </group>
                    <group>
                        <group string="Schedule">
                            <field name="scheduled_departure"/>
                            <field name="scheduled_arrival"/>
                        </group>
                        <group string="Actuals">
                            <field name="actual_departure" readonly="1"/>
                            <field name="actual_arrival" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="purpose"/>
                    </group>
                    <notebook>
                        <page string="Notes" name="notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_transit_trip_calendar" model="ir.ui.view">
        <field name="name">transit.trip.calendar</field>
        <field name="model">transit.trip</field>
        <field name="arch" type="xml">
            <calendar string="Trips" date_start="scheduled_departure" date_stop="scheduled_arrival"
                      color="state" mode="week">
                <field name="vehicle_id"/>
                <field name="driver_id"/>
                <field name="state"/>
            </calendar>
        </field>
    </record>

    <record id="view_transit_trip_search" model="ir.ui.view">
        <field name="name">transit.trip.search</field>
        <field name="model">transit.trip</field>
        <field name="arch" type="xml">
            <search string="Search Trips">
                <field name="name"/>
                <field name="vehicle_id"/>
                <field name="driver_id"/>
                <field name="origin"/>
                <field name="destination"/>
                <filter string="Draft" name="filter_draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Scheduled" name="filter_scheduled" domain="[('state', '=', 'scheduled')]"/>
                <filter string="In Progress" name="filter_in_progress" domain="[('state', '=', 'in_progress')]"/>
                <filter string="Completed" name="filter_completed" domain="[('state', '=', 'completed')]"/>
                <filter string="Today" name="filter_today"
                        domain="[('scheduled_departure', '&gt;=', context_today().strftime('%Y-%m-%d 00:00:00')),
                                 ('scheduled_departure', '&lt;=', context_today().strftime('%Y-%m-%d 23:59:59'))]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Vehicle" name="group_vehicle" context="{'group_by': 'vehicle_id'}"/>
                    <filter string="Driver" name="group_driver" context="{'group_by': 'driver_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_transit_trip" model="ir.actions.act_window">
        <field name="name">Trips</field>
        <field name="res_model">transit.trip</field>
        <field name="view_mode">list,form,calendar</field>
        <field name="search_view_id" ref="view_transit_trip_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Dispatch your first trip
            </p>
            <p>
                Plan, assign and track trips from dispatch to completion.
            </p>
        </field>
    </record>

</odoo>
