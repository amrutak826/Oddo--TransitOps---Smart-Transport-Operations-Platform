<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- ================= MODULE CATEGORY ================= -->
        <record id="module_category_transit_ops" model="ir.module.category">
            <field name="name">TransitOps</field>
            <field name="description">Smart Transport Operations Platform</field>
            <field name="sequence">15</field>
        </record>

        <!-- ================= SECURITY GROUPS ================= -->

        <!-- Viewer: read-only access across the app -->
        <record id="group_transit_viewer" model="res.groups">
            <field name="name">Viewer</field>
            <field name="category_id" ref="module_category_transit_ops"/>
            <field name="comment">Read-only access to TransitOps records (vehicles, drivers, trips, maintenance, fuel, reports).</field>
        </record>

        <!-- Driver: restricted operational access, mainly own trips/vehicle -->
        <record id="group_transit_driver" model="res.groups">
            <field name="name">Driver</field>
            <field name="category_id" ref="module_category_transit_ops"/>
            <field name="implied_ids" eval="[(4, ref('group_transit_viewer'))]"/>
            <field name="comment">Drivers can view and update their own assigned trips, log fuel and expenses.</field>
        </record>

        <!-- Dispatcher: manages trips, vehicles, drivers day to day -->
        <record id="group_transit_dispatcher" model="res.groups">
            <field name="name">Dispatcher</field>
            <field name="category_id" ref="module_category_transit_ops"/>
            <field name="implied_ids" eval="[(4, ref('group_transit_viewer'))]"/>
            <field name="comment">Dispatchers create and manage trips, assign vehicles and drivers, monitor operations.</field>
        </record>

        <!-- Manager: full administrative access -->
        <record id="group_transit_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="category_id" ref="module_category_transit_ops"/>
            <field name="implied_ids" eval="[(4, ref('group_transit_dispatcher')), (4, ref('group_transit_driver'))]"/>
            <field name="comment">Full administrative access: configuration, security, maintenance approval, financial reports.</field>
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
        </record>

        <!-- ================= RECORD RULES ================= -->

        <record id="rule_transit_vehicle_company" model="ir.rule">
            <field name="name">Transit Vehicle: multi-company</field>
            <field name="model_id" ref="model_transit_vehicle"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>

        <record id="rule_transit_trip_company" model="ir.rule">
            <field name="name">Transit Trip: multi-company</field>
            <field name="model_id" ref="model_transit_trip"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>

        <record id="rule_transit_trip_driver_own" model="ir.rule">
            <field name="name">Transit Trip: driver sees own trips only</field>
            <field name="model_id" ref="model_transit_trip"/>
            <field name="groups" eval="[(4, ref('group_transit_driver'))]"/>
            <field name="domain_force">[('driver_id.user_id', '=', user.id)]</field>
        </record>

        <record id="rule_transit_trip_dispatcher_all" model="ir.rule">
            <field name="name">Transit Trip: dispatcher sees all trips</field>
            <field name="model_id" ref="model_transit_trip"/>
            <field name="groups" eval="[(4, ref('group_transit_dispatcher'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>

        <record id="rule_transit_trip_manager_all" model="ir.rule">
            <field name="name">Transit Trip: manager sees all trips</field>
            <field name="model_id" ref="model_transit_trip"/>
            <field name="groups" eval="[(4, ref('group_transit_manager'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>

        <record id="rule_transit_fuel_log_driver_own" model="ir.rule">
            <field name="name">Transit Fuel Log: driver sees own logs only</field>
            <field name="model_id" ref="model_transit_fuel_log"/>
            <field name="groups" eval="[(4, ref('group_transit_driver'))]"/>
            <field name="domain_force">[('driver_id.user_id', '=', user.id)]</field>
        </record>

        <record id="rule_transit_fuel_log_dispatcher_all" model="ir.rule">
            <field name="name">Transit Fuel Log: dispatcher sees all logs</field>
            <field name="model_id" ref="model_transit_fuel_log"/>
            <field name="groups" eval="[(4, ref('group_transit_dispatcher'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>

        <record id="rule_transit_fuel_log_manager_all" model="ir.rule">
            <field name="name">Transit Fuel Log: manager sees all logs</field>
            <field name="model_id" ref="model_transit_fuel_log"/>
            <field name="groups" eval="[(4, ref('group_transit_manager'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>

    </data>
</odoo>
