<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="seq_transit_vehicle" model="ir.sequence">
            <field name="name">TransitOps Vehicle Fleet Code</field>
            <field name="code">transit.vehicle</field>
            <field name="prefix">VEH-</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_transit_driver" model="ir.sequence">
            <field name="name">TransitOps Driver Code</field>
            <field name="code">transit.driver</field>
            <field name="prefix">DRV-</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_transit_trip" model="ir.sequence">
            <field name="name">TransitOps Trip Reference</field>
            <field name="code">transit.trip</field>
            <field name="prefix">TRIP-%(year)s-</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_transit_maintenance" model="ir.sequence">
            <field name="name">TransitOps Maintenance Reference</field>
            <field name="code">transit.maintenance</field>
            <field name="prefix">MNT-%(year)s-</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_transit_fuel_log" model="ir.sequence">
            <field name="name">TransitOps Fuel Log Reference</field>
            <field name="code">transit.fuel.log</field>
            <field name="prefix">FUEL-%(year)s-</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_transit_expense" model="ir.sequence">
            <field name="name">TransitOps Expense Reference</field>
            <field name="code">transit.expense</field>
            <field name="prefix">EXP-%(year)s-</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

    </data>
</odoo>
