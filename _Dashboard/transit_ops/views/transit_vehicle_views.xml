<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================= List View ================= -->
    <record id="view_transit_vehicle_list" model="ir.ui.view">
        <field name="name">transit.vehicle.list</field>
        <field name="model">transit.vehicle</field>
        <field name="arch" type="xml">
            <list string="Vehicles" decoration-danger="document_status=='expired'"
                  decoration-warning="document_status=='expiring_soon'"
                  decoration-muted="state=='inactive'">
                <field name="sequence_code"/>
                <field name="name"/>
                <field name="vehicle_type"/>
                <field name="make"/>
                <field name="model"/>
                <field name="driver_id"/>
                <field name="odometer" sum="Total Odometer"/>
                <field name="fuel_type"/>
                <field name="document_status" widget="badge"
                       decoration-success="document_status=='valid'"
                       decoration-warning="document_status=='expiring_soon'"
                       decoration-danger="document_status=='expired'"/>
                <field name="state" widget="badge"
                       decoration-success="state=='available'"
                       decoration-info="state=='on_trip'"
                       decoration-warning="state=='maintenance'"
                       decoration-muted="state=='inactive'"/>
            </list>
        </field>
    </record>

    <!-- ================= Form View ================= -->
    <record id="view_transit_vehicle_form" model="ir.ui.view">
        <field name="name">transit.vehicle.form</field>
        <field name="model">transit.vehicle</field>
        <field name="arch" type="xml">
            <form string="Vehicle">
                <header>
                    <button name="action_set_available" type="object" string="Mark Available"
                            class="btn-primary" invisible="state == 'available'"/>
                    <button name="action_set_maintenance" type="object" string="Send to Maintenance"
                            class="btn-secondary" invisible="state == 'maintenance'"/>
                    <button name="action_set_inactive" type="object" string="Mark Inactive"
                            class="btn-secondary" invisible="state == 'inactive'"/>
                    <field name="state" widget="statusbar" statusbar_visible="available,on_trip,maintenance,inactive"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_trips" type="object" class="oe_stat_button" icon="fa-road">
                            <field name="trip_count" widget="statinfo" string="Trips"/>
                        </button>
                        <button name="action_view_maintenance" type="object" class="oe_stat_button" icon="fa-wrench">
                            <field name="maintenance_count" widget="statinfo" string="Maintenance"/>
                        </button>
                        <button name="action_view_fuel_logs" type="object" class="oe_stat_button" icon="fa-tint">
                            <field name="fuel_log_count" widget="statinfo" string="Fuel Logs"/>
                        </button>
                    </div>
                    <field name="image" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="e.g. KA-01-AB-1234"/></h1>
                        <h3><field name="sequence_code" readonly="1"/></h3>
                    </div>
                    <group>
                        <group string="Vehicle Details">
                            <field name="vehicle_type"/>
                            <field name="make"/>
                            <field name="model"/>
                            <field name="year"/>
                            <field name="color"/>
                            <field name="fuel_type"/>
                            <field name="seating_capacity"/>
                            <field name="odometer"/>
                        </group>
                        <group string="Identification">
                            <field name="chassis_number"/>
                            <field name="engine_number"/>
                            <field name="registration_date"/>
                            <field name="driver_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Documents &amp; Compliance">
                            <group>
                                <group string="Insurance">
                                    <field name="insurance_number"/>
                                    <field name="insurance_expiry"/>
                                </group>
                                <group string="Permit &amp; Fitness">
                                    <field name="permit_number"/>
                                    <field name="permit_expiry"/>
                                    <field name="puc_number"/>
                                    <field name="puc_expiry"/>
                                    <field name="fitness_expiry"/>
                                </group>
                            </group>
                            <group>
                                <field name="document_status" widget="badge"
                                       decoration-success="document_status=='valid'"
                                       decoration-warning="document_status=='expiring_soon'"
                                       decoration-danger="document_status=='expired'"/>
                            </group>
                        </page>
                        <page string="Costs">
                            <group>
                                <field name="total_fuel_cost"/>
                                <field name="total_maintenance_cost"/>
                                <field name="currency_id" invisible="1"/>
                            </group>
                        </page>
                        <page string="Notes">
                            <field name="notes" placeholder="Internal notes about this vehicle..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ================= Kanban View ================= -->
    <record id="view_transit_vehicle_kanban" model="ir.ui.view">
        <field name="name">transit.vehicle.kanban</field>
        <field name="model">transit.vehicle</field>
        <field name="arch" type="xml">
            <kanban class="o_transit_kanban" quick_create="false">
                <field name="name"/>
                <field name="vehicle_type"/>
                <field name="state"/>
                <field name="driver_id"/>
                <field name="document_status"/>
                <field name="image"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click o_transit_vehicle_card">
                            <div class="o_kanban_image">
                                <img t-att-src="kanban_image('transit.vehicle', 'image', record.id.raw_value)" alt="Vehicle" class="o_transit_kanban_img"/>
                            </div>
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title"><field name="name"/></strong>
                                <div class="text-muted">
                                    <field name="vehicle_type"/> · <field name="driver_id"/>
                                </div>
                                <div class="mt-2">
                                    <field name="state" widget="badge"
                                           decoration-success="state=='available'"
                                           decoration-info="state=='on_trip'"
                                           decoration-warning="state=='maintenance'"
                                           decoration-muted="state=='inactive'"/>
                                    <field name="document_status" widget="badge"
                                           decoration-success="document_status=='valid'"
                                           decoration-warning="document_status=='expiring_soon'"
                                           decoration-danger="document_status=='expired'"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ================= Search View ================= -->
    <record id="view_transit_vehicle_search" model="ir.ui.view">
        <field name="name">transit.vehicle.search</field>
        <field name="model">transit.vehicle</field>
        <field name="arch" type="xml">
            <search string="Search Vehicles">
                <field name="name" string="Vehicle" filter_domain="['|', ('name', 'ilike', self), ('sequence_code', 'ilike', self)]"/>
                <field name="driver_id"/>
                <field name="vehicle_type"/>
                <filter string="Available" name="filter_available" domain="[('state', '=', 'available')]"/>
                <filter string="On Trip" name="filter_on_trip" domain="[('state', '=', 'on_trip')]"/>
                <filter string="Under Maintenance" name="filter_maintenance" domain="[('state', '=', 'maintenance')]"/>
                <filter string="Inactive" name="filter_inactive" domain="[('state', '=', 'inactive')]"/>
                <separator/>
                <filter string="Documents Expiring Soon" name="filter_doc_expiring" domain="[('document_status', '=', 'expiring_soon')]"/>
                <filter string="Documents Expired" name="filter_doc_expired" domain="[('document_status', '=', 'expired')]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Vehicle Type" name="group_type" context="{'group_by': 'vehicle_type'}"/>
                    <filter string="Fuel Type" name="group_fuel" context="{'group_by': 'fuel_type'}"/>
                    <filter string="Driver" name="group_driver" context="{'group_by': 'driver_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ================= Action ================= -->
    <record id="action_transit_vehicle" model="ir.actions.act_window">
        <field name="name">Vehicles</field>
        <field name="res_model">transit.vehicle</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_transit_vehicle_search"/>
        <field name="context">{'search_default_filter_available': 0}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Register your first vehicle
            </p>
            <p>
                Track vehicle details, compliance documents, assignments and costs.
            </p>
        </field>
    </record>

</odoo>
