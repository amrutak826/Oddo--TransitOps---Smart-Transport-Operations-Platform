<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_transit_driver_list" model="ir.ui.view">
        <field name="name">transit.driver.list</field>
        <field name="model">transit.driver</field>
        <field name="arch" type="xml">
            <list string="Drivers">
                <field name="driver_code"/>
                <field name="name"/>
                <field name="phone"/>
                <field name="license_number"/>
                <field name="license_expiry_date"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_transit_driver_form" model="ir.ui.view">
        <field name="name">transit.driver.form</field>
        <field name="model">transit.driver</field>
        <field name="arch" type="xml">
            <form string="Driver">
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="active,on_leave,inactive"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Driver Name"/></h1>
                        <field name="driver_code" readonly="1"/>
                    </div>
                    <group>
                        <group string="Contact">
                            <field name="user_id"/>
                            <field name="phone"/>
                            <field name="email"/>
                        </group>
                        <group string="License">
                            <field name="license_number"/>
                            <field name="license_expiry_date"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_transit_driver" model="ir.actions.act_window">
        <field name="name">Drivers</field>
        <field name="res_model">transit.driver</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Add your first driver.</p>
        </field>
    </record>

</odoo>
