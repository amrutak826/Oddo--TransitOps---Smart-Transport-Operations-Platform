<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <record id="module_category_transit_ops" model="ir.module.category">
            <field name="name">TransitOps</field>
            <field name="description">Smart Transport Operations Platform</field>
            <field name="sequence">20</field>
        </record>

        <record id="group_transit_driver" model="res.groups">
            <field name="name">Driver</field>
            <field name="category_id" ref="module_category_transit_ops"/>
            <field name="comment">Drivers can view their own trips, log fuel and expenses.</field>
        </record>

        <record id="group_transit_dispatcher" model="res.groups">
            <field name="name">Dispatcher</field>
            <field name="category_id" ref="module_category_transit_ops"/>
            <field name="implied_ids" eval="[(4, ref('group_transit_driver'))]"/>
            <field name="comment">Dispatchers manage vehicles, drivers and trip assignments.</field>
        </record>

        <record id="group_transit_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="category_id" ref="module_category_transit_ops"/>
            <field name="implied_ids" eval="[(4, ref('group_transit_dispatcher'))]"/>
            <field name="comment">Full access including reports, maintenance and configuration.</field>
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
        </record>

        <!-- Driver -->
        <record id="rule_driver_own_record" model="ir.rule">
            <field name="name">Driver: Own Record Only</field>
            <field name="model_id" ref="model_transit_driver"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_transit_driver'))]"/>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">0</field>
            <field name="perm_unlink">0</field>
        </record>
        <record id="rule_driver_dispatcher_all" model="ir.rule">
            <field name="name">Dispatcher/Manager: All Drivers</field>
            <field name="model_id" ref="model_transit_driver"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_transit_dispatcher'))]"/>
        </record>

        <!-- Trip -->
        <record id="rule_trip_own_record" model="ir.rule">
            <field name="name">Driver: Own Trips Only</field>
            <field name="model_id" ref="model_transit_trip"/>
            <field name="domain_force">[('driver_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_transit_driver'))]"/>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">0</field>
            <field name="perm_unlink">0</field>
        </record>
        <record id="rule_trip_dispatcher_all" model="ir.rule">
            <field name="name">Dispatcher/Manager: All Trips</field>
            <field name="model_id" ref="model_transit_trip"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_transit_dispatcher'))]"/>
        </record>

        <!-- Fuel Log -->
        <record id="rule_fuel_own_record" model="ir.rule">
            <field name="name">Driver: Own Fuel Logs Only</field>
            <field name="model_id" ref="model_transit_fuel_log"/>
            <field name="domain_force">[('driver_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_transit_driver'))]"/>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
            <field name="perm_unlink">0</field>
        </record>
        <record id="rule_fuel_dispatcher_all" model="ir.rule">
            <field name="name">Dispatcher/Manager: All Fuel Logs</field>
            <field name="model_id" ref="model_transit_fuel_log"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_transit_dispatcher'))]"/>
        </record>

        <!-- Notification: every operational role only ever sees their own -->
        <record id="rule_notification_own_record" model="ir.rule">
            <field name="name">All Roles: Own Notifications Only</field>
            <field name="model_id" ref="model_transit_notification"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_transit_driver'))]"/>
        </record>

    </data>
</odoo>
