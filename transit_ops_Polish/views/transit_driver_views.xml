<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_transit_driver_list" model="ir.ui.view">
        <field name="name">transit.driver.list</field>
        <field name="model">transit.driver</field>
        <field name="arch" type="xml">
            <list string="Drivers" decoration-muted="state == 'inactive'"
                  decoration-warning="license_alert_state == 'warning'"
                  decoration-danger="license_alert_state == 'expired'">
                <field name="name"/>
                <field name="employee_code"/>
                <field name="license_number"/>
                <field name="license_type"/>
                <field name="phone"/>
                <field name="license_alert_state" widget="badge"
                       decoration-success="license_alert_state == 'ok'"
                       decoration-warning="license_alert_state == 'warning'"
                       decoration-danger="license_alert_state == 'expired'"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'available'"
                       decoration-info="state == 'on_trip'"
                       decoration-warning="state == 'on_leave'"
                       decoration-muted="state == 'inactive'"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_transit_driver_form" model="ir.ui.view">
        <field name="name">transit.driver.form</field>
        <field name="model">transit.driver</field>
        <field name="arch" type="xml">
            <form string="Driver">
                <header>
                    <button name="action_set_available" string="Set Available" type="object"
                            class="oe_highlight" invisible="state == 'available'"/>
                    <button name="action_set_on_leave" string="Set On Leave" type="object"
                            invisible="state == 'on_leave'"/>
                    <button name="action_set_inactive" string="Set Inactive" type="object"
                            invisible="state == 'inactive'"/>
                    <field name="state" widget="statusbar" statusbar_visible="available,on_trip,on_leave"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_trips" type="object" class="oe_stat_button" icon="fa-road">
                            <field name="trip_count" widget="statinfo" string="Trips"/>
                        </button>
                        <button name="action_view_vehicles" type="object" class="oe_stat_button" icon="fa-truck">
                            <field name="vehicle_count" widget="statinfo" string="Vehicles"/>
                        </button>
                    </div>
                    <field name="image_1920" widget="image" class="oe_avatar" options="{'preview_image': 'image_1920'}"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Driver Name"/>
                        </h1>
                    </div>
                    <widget name="web_ribbon" title="License Expired" bg_color="text-bg-danger"
                            invisible="license_alert_state != 'expired'"/>
                    <widget name="web_ribbon" title="License Expiring" bg_color="text-bg-warning"
                            invisible="license_alert_state != 'warning'"/>
                    <group>
                        <group string="Identification">
                            <field name="employee_code"/>
                            <field name="user_id"/>
                            <field name="date_of_birth"/>
                            <field name="date_of_joining"/>
                        </group>
                        <group string="Contact">
                            <field name="phone"/>
                            <field name="mobile"/>
                            <field name="email"/>
                        </group>
                    </group>
                    <group>
                        <group string="License">
                            <field name="license_number"/>
                            <field name="license_type"/>
                            <field name="license_expiry_date"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Address" name="address">
                            <field name="address"/>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_transit_driver_search" model="ir.ui.view">
        <field name="name">transit.driver.search</field>
        <field name="model">transit.driver</field>
        <field name="arch" type="xml">
            <search string="Search Drivers">
                <field name="name" string="Driver" filter_domain="['|', ('name', 'ilike', self), ('license_number', 'ilike', self)]"/>
                <field name="employee_code"/>
                <field name="license_number"/>
                <filter string="Available" name="filter_available" domain="[('state', '=', 'available')]"/>
                <filter string="On Trip" name="filter_on_trip" domain="[('state', '=', 'on_trip')]"/>
                <filter string="License Expiring/Expired" name="filter_license_alert"
                        domain="[('license_alert_state', '!=', 'ok')]"/>
                <separator/>
                <filter string="Archived" name="filter_archived" domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="License Type" name="group_license_type" context="{'group_by': 'license_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_transit_driver" model="ir.actions.act_window">
        <field name="name">Drivers</field>
        <field name="res_model">transit.driver</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_transit_driver_search"/>
        <field name="context">{'search_default_filter_available': 0}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add your first driver
            </p>
            <p>
                Track licenses, contact details, and trip history for every driver.
            </p>
        </field>
    </record>

</odoo>
