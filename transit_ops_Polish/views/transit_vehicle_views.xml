<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ===================== LIST VIEW ===================== -->
    <record id="view_transit_vehicle_list" model="ir.ui.view">
        <field name="name">transit.vehicle.list</field>
        <field name="model">transit.vehicle</field>
        <field name="arch" type="xml">
            <list string="Vehicles" decoration-muted="state == 'retired'"
                  decoration-warning="document_alert_state == 'warning'"
                  decoration-danger="document_alert_state == 'expired'">
                <field name="name"/>
                <field name="license_plate"/>
                <field name="vehicle_type"/>
                <field name="brand"/>
                <field name="model"/>
                <field name="default_driver_id"/>
                <field name="odometer" sum="Total Odometer"/>
                <field name="fuel_type"/>
                <field name="document_alert_state" widget="badge"
                       decoration-success="document_alert_state == 'ok'"
                       decoration-warning="document_alert_state == 'warning'"
                       decoration-danger="document_alert_state == 'expired'"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'active'"
                       decoration-info="state == 'on_trip'"
                       decoration-warning="state == 'maintenance'"
                       decoration-muted="state in ('inactive', 'retired')"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <!-- ===================== FORM VIEW ===================== -->
    <record id="view_transit_vehicle_form" model="ir.ui.view">
        <field name="name">transit.vehicle.form</field>
        <field name="model">transit.vehicle</field>
        <field name="arch" type="xml">
            <form string="Vehicle">
                <header>
                    <button name="action_set_active" string="Set Active" type="object"
                            class="oe_highlight" invisible="state == 'active'"/>
                    <button name="action_set_maintenance" string="Send to Maintenance" type="object"
                            invisible="state == 'maintenance'"/>
                    <button name="action_set_inactive" string="Set Inactive" type="object"
                            invisible="state == 'inactive'"/>
                    <button name="action_set_retired" string="Retire" type="object"
                            confirm="Are you sure you want to retire this vehicle? It will be archived."
                            invisible="state == 'retired'"/>
                    <field name="state" widget="statusbar" statusbar_visible="active,on_trip,maintenance,inactive"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_trips" type="object" class="oe_stat_button" icon="fa-road">
                            <field name="trip_count" widget="statinfo" string="Trips"/>
                        </button>
                        <button name="action_view_maintenance" type="object" class="oe_stat_button" icon="fa-wrench">
                            <field name="maintenance_count" widget="statinfo" string="Maintenance"/>
                        </button>
                        <button name="action_view_fuel_logs" type="object" class="oe_stat_button" icon="fa-tint">
                            <field name="fuel_log_count" widget="statinfo" string="Fuel Logs"/>
                        </button>
                    </div>
                    <field name="image_1920" widget="image" class="oe_avatar" options="{'preview_image': 'image_1920'}"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="e.g. Bus 12"/>
                        </h1>
                        <h3>
                            <field name="license_plate" placeholder="License Plate Number"/>
                        </h3>
                    </div>
                    <widget name="web_ribbon" title="Document Expired" bg_color="text-bg-danger"
                            invisible="document_alert_state != 'expired'"/>
                    <widget name="web_ribbon" title="Expiring Soon" bg_color="text-bg-warning"
                            invisible="document_alert_state != 'warning'"/>
                    <group>
                        <group string="Classification">
                            <field name="vehicle_type"/>
                            <field name="fuel_type"/>
                            <field name="brand"/>
                            <field name="model"/>
                            <field name="color"/>
                            <field name="year_of_manufacture"/>
                        </group>
                        <group string="Capacity &amp; Usage">
                            <field name="seating_capacity"/>
                            <field name="load_capacity_kg"/>
                            <label for="odometer"/>
                            <div class="o_row">
                                <field name="odometer"/>
                                <field name="odometer_unit"/>
                            </div>
                            <field name="default_driver_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Documents &amp; Compliance" name="documents">
                            <group>
                                <group string="Registration">
                                    <field name="registration_number"/>
                                    <field name="registration_expiry_date"/>
                                    <field name="permit_expiry_date"/>
                                </group>
                                <group string="Insurance &amp; Pollution">
                                    <field name="insurance_number"/>
                                    <field name="insurance_expiry_date"/>
                                    <field name="puc_expiry_date"/>
                                </group>
                            </group>
                            <group>
                                <field name="vin"/>
                            </group>
                        </page>
                        <page string="Financial" name="financial">
                            <group>
                                <field name="purchase_date"/>
                                <field name="purchase_value"/>
                                <field name="currency_id" groups="base.group_multi_currency"/>
                            </group>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ===================== KANBAN VIEW ===================== -->
    <record id="view_transit_vehicle_kanban" model="ir.ui.view">
        <field name="name">transit.vehicle.kanban</field>
        <field name="model">transit.vehicle</field>
        <field name="arch" type="xml">
            <kanban class="o_transit_ops o_kanban_dashboard" records_draggable="false">
                <field name="name"/>
                <field name="license_plate"/>
                <field name="vehicle_type"/>
                <field name="state"/>
                <field name="document_alert_state"/>
                <field name="default_driver_id"/>
                <field name="image_1920"/>
                <templates>
                    <t t-name="card" t-att-class="'o_transit_card'">
                        <div class="d-flex align-items-center">
                            <img t-if="record.image_1920.raw_value"
                                 t-att-src="kanban_image('transit.vehicle', 'image_1920', record.id.raw_value)"
                                 class="o_kanban_image rounded me-2"
                                 style="width:48px;height:48px;object-fit:cover;"/>
                            <div t-else="" class="rounded me-2 d-flex align-items-center justify-content-center"
                                 style="width:48px;height:48px;background-color:var(--transit-accent-soft);color:var(--transit-accent);font-weight:bold;">
                                <t t-esc="record.license_plate.value"/>
                            </div>
                            <div>
                                <div class="o_transit_card_title"><field name="name"/></div>
                                <div class="o_transit_card_subtitle"><field name="license_plate"/></div>
                            </div>
                        </div>
                        <div class="o_transit_card_footer">
                            <span t-attf-class="o_transit_pill {{
                                record.state.raw_value == 'active' ? 'o_transit_pill_success' :
                                record.state.raw_value == 'on_trip' ? 'o_transit_pill_info' :
                                record.state.raw_value == 'maintenance' ? 'o_transit_pill_warning' :
                                'o_transit_pill_muted' }}">
                                <field name="state"/>
                            </span>
                            <span t-if="record.document_alert_state.raw_value != 'ok'"
                                  t-attf-class="o_transit_pill {{
                                  record.document_alert_state.raw_value == 'expired' ? 'o_transit_pill_danger' : 'o_transit_pill_warning' }}">
                                <t t-if="record.document_alert_state.raw_value == 'expired'">Expired</t>
                                <t t-else="">Expiring</t>
                            </span>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ===================== SEARCH VIEW ===================== -->
    <record id="view_transit_vehicle_search" model="ir.ui.view">
        <field name="name">transit.vehicle.search</field>
        <field name="model">transit.vehicle</field>
        <field name="arch" type="xml">
            <search string="Search Vehicles">
                <field name="name" string="Vehicle" filter_domain="['|', ('name', 'ilike', self), ('license_plate', 'ilike', self)]"/>
                <field name="license_plate"/>
                <field name="default_driver_id"/>
                <field name="vehicle_type"/>
                <filter string="Active" name="filter_active" domain="[('state', '=', 'active')]"/>
                <filter string="On Trip" name="filter_on_trip" domain="[('state', '=', 'on_trip')]"/>
                <filter string="Under Maintenance" name="filter_maintenance" domain="[('state', '=', 'maintenance')]"/>
                <filter string="Documents Expiring/Expired" name="filter_doc_alert"
                        domain="[('document_alert_state', '!=', 'ok')]"/>
                <separator/>
                <filter string="Archived" name="filter_archived" domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Vehicle Type" name="group_type" context="{'group_by': 'vehicle_type'}"/>
                    <filter string="Fuel Type" name="group_fuel" context="{'group_by': 'fuel_type'}"/>
                    <filter string="Default Driver" name="group_driver" context="{'group_by': 'default_driver_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ===================== ACTION ===================== -->
    <record id="action_transit_vehicle" model="ir.actions.act_window">
        <field name="name">Vehicles</field>
        <field name="res_model">transit.vehicle</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_transit_vehicle_search"/>
        <field name="context">{'search_default_filter_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Register your first vehicle
            </p>
            <p>
                Track license plates, documents, insurance, maintenance and fuel usage for your entire fleet.
            </p>
        </field>
    </record>

</odoo>
