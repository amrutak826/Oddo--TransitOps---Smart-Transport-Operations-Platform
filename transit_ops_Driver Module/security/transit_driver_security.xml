<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ================================================================
             Driver group: can only see their own linked driver record
             (self-service). Records with no linked user remain hidden from
             this rule, which is intentional — only claimed profiles are
             visible to their owner.
        ================================================================= -->
        <record id="rule_transit_driver_self_only" model="ir.rule">
            <field name="name">Driver: only own record</field>
            <field name="model_id" ref="model_transit_driver"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_transit_driver'))]"/>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">0</field>
            <field name="perm_unlink">0</field>
        </record>

        <!-- ================================================================
             Dispatcher and Manager groups both imply the Driver group, so
             without these unrestricted rules they would be OR'd together
             with the self-only rule above and accidentally get scoped down
             to "own record only" as well. These rules restore full
             visibility for the roles that actually manage drivers.
        ================================================================= -->
        <record id="rule_transit_driver_dispatcher_all" model="ir.rule">
            <field name="name">Dispatcher: all driver records</field>
            <field name="model_id" ref="model_transit_driver"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_transit_dispatcher'))]"/>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
            <field name="perm_unlink">0</field>
        </record>

        <record id="rule_transit_driver_manager_all" model="ir.rule">
            <field name="name">Manager: all driver records</field>
            <field name="model_id" ref="model_transit_driver"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_transit_manager'))]"/>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
            <field name="perm_unlink">1</field>
        </record>

    </data>
</odoo>
