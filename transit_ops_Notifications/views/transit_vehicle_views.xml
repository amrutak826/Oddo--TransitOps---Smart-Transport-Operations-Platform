<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_transit_vehicle_list" model="ir.ui.view">
        <field name="name">transit.vehicle.list</field>
        <field name="model">transit.vehicle</field>
        <field name="arch" type="xml">
            <list string="Vehicles" decoration-danger="compliance_alert">
                <field name="vehicle_code"/>
                <field name="name"/>
                <field name="vehicle_type"/>
                <field name="driver_id"/>
                <field name="state" widget="badge"/>
                <field name="insurance_status" widget="badge" decoration-danger="insurance_status == 'expired'" decoration-warning="insurance_status == 'expiring_soon'" decoration-success="insurance_status == 'valid'"/>
                <field name="monthly_fuel_budget"/>
                <field name="total_fuel_cost"/>
            </list>
        </field>
    </record>

    <record id="view_transit_vehicle_form" model="ir.ui.view">
        <field name="name">transit.vehicle.form</field>
        <field name="model">transit.vehicle</field>
        <field name="arch" type="xml">
            <form string="Vehicle">
                <header>
                    <button name="action_set_available" type="object" string="Set Available" class="btn-primary" invisible="state == 'available'"/>
                    <button name="action_set_maintenance" type="object" string="Send to Maintenance" invisible="state == 'maintenance'"/>
                    <button name="action_set_inactive" type="object" string="Deactivate" invisible="state == 'inactive'"/>
                    <field name="state" widget="statusbar" statusbar_visible="available,on_trip,maintenance,inactive"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_trips" type="object" class="oe_stat_button" icon="fa-road">
                            <field name="trip_count" widget="statinfo" string="Trips"/>
                        </button>
                        <button name="action_view_maintenance" type="object" class="oe_stat_button" icon="fa-wrench">
                            <field name="maintenance_count" widget="statinfo" string="Maintenance"/>
                        </button>
                        <button name="action_view_fuel_logs" type="object" class="oe_stat_button" icon="fa-tint">
                            <field name="fuel_log_count" widget="statinfo" string="Fuel Logs"/>
                        </button>
                    </div>
                    <field name="image" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Vehicle Number"/></h1>
                        <field name="vehicle_code" readonly="1"/>
                    </div>
                    <group>
                        <group string="Details">
                            <field name="vehicle_type"/>
                            <field name="brand"/>
                            <field name="model"/>
                            <field name="year"/>
                            <field name="color"/>
                            <field name="seating_capacity"/>
                            <field name="fuel_type"/>
                            <field name="odometer"/>
                        </group>
                        <group string="Assignment &amp; Budget">
                            <field name="driver_id"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="monthly_fuel_budget"/>
                            <field name="total_fuel_cost"/>
                        </group>
                    </group>
                    <group string="Compliance">
                        <group>
                            <field name="registration_date"/>
                            <field name="insurance_expiry"/>
                            <field name="insurance_status" readonly="1"/>
                        </group>
                        <group>
                            <field name="permit_expiry"/>
                            <field name="puc_expiry"/>
                            <field name="fitness_expiry"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_transit_vehicle" model="ir.actions.act_window">
        <field name="name">Vehicles</field>
        <field name="res_model">transit.vehicle</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Register your first vehicle.</p>
        </field>
    </record>

</odoo>
