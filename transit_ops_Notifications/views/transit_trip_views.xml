<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_transit_trip_list" model="ir.ui.view">
        <field name="name">transit.trip.list</field>
        <field name="model">transit.trip</field>
        <field name="arch" type="xml">
            <list string="Trips" decoration-danger="state == 'delayed'" decoration-success="state == 'completed'">
                <field name="name"/>
                <field name="vehicle_id"/>
                <field name="driver_id"/>
                <field name="origin"/>
                <field name="destination"/>
                <field name="scheduled_departure"/>
                <field name="scheduled_arrival"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_transit_trip_form" model="ir.ui.view">
        <field name="name">transit.trip.form</field>
        <field name="model">transit.trip</field>
        <field name="arch" type="xml">
            <form string="Trip">
                <header>
                    <button name="action_start_trip" type="object" string="Start Trip" class="btn-primary" invisible="state != 'scheduled'"/>
                    <button name="action_complete_trip" type="object" string="Complete Trip" class="btn-primary" invisible="state not in ('ongoing', 'delayed')"/>
                    <button name="action_cancel_trip" type="object" string="Cancel" invisible="state in ('completed', 'cancelled')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,scheduled,ongoing,completed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Assignment">
                            <field name="vehicle_id"/>
                            <field name="driver_id"/>
                        </group>
                        <group string="Route">
                            <field name="origin"/>
                            <field name="destination"/>
                        </group>
                    </group>
                    <group string="Schedule">
                        <group>
                            <field name="scheduled_departure"/>
                            <field name="scheduled_arrival"/>
                        </group>
                        <group>
                            <field name="actual_departure"/>
                            <field name="actual_arrival"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_transit_trip" model="ir.actions.act_window">
        <field name="name">Trips</field>
        <field name="res_model">transit.trip</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Dispatch your first trip.</p>
        </field>
    </record>

</odoo>
