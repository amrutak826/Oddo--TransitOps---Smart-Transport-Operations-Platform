<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_transit_notification_list" model="ir.ui.view">
        <field name="name">transit.notification.list</field>
        <field name="model">transit.notification</field>
        <field name="arch" type="xml">
            <list string="Notifications" decoration-muted="is_read" decoration-danger="severity == 'danger' and not is_read" decoration-warning="severity == 'warning' and not is_read">
                <field name="date"/>
                <field name="notification_type"/>
                <field name="name"/>
                <field name="severity" widget="badge" decoration-danger="severity == 'danger'" decoration-warning="severity == 'warning'" decoration-info="severity == 'info'"/>
                <field name="vehicle_id" optional="show"/>
                <field name="driver_id" optional="hide"/>
                <field name="trip_id" optional="hide"/>
                <field name="is_read" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_transit_notification_form" model="ir.ui.view">
        <field name="name">transit.notification.form</field>
        <field name="model">transit.notification</field>
        <field name="arch" type="xml">
            <form string="Notification">
                <header>
                    <button name="action_mark_read" type="object" string="Mark as Read"
                            class="btn-primary" invisible="is_read"/>
                    <button name="action_open_related" type="object" string="Open Related Record"
                            class="btn-secondary" invisible="not res_model"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="notification_type"/>
                            <field name="severity"/>
                            <field name="user_id"/>
                        </group>
                        <group>
                            <field name="date"/>
                            <field name="is_read"/>
                            <field name="read_date" invisible="not is_read"/>
                        </group>
                    </group>
                    <group string="Related Records">
                        <field name="vehicle_id"/>
                        <field name="driver_id"/>
                        <field name="trip_id"/>
                    </group>
                    <group string="Message">
                        <field name="message" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_transit_notification_search" model="ir.ui.view">
        <field name="name">transit.notification.search</field>
        <field name="model">transit.notification</field>
        <field name="arch" type="xml">
            <search string="Search Notifications">
                <field name="name"/>
                <field name="vehicle_id"/>
                <field name="driver_id"/>
                <field name="trip_id"/>
                <filter string="Unread" name="filter_unread" domain="[('is_read', '=', False)]"/>
                <filter string="Critical" name="filter_critical" domain="[('severity', '=', 'danger')]"/>
                <separator/>
                <filter string="Insurance Expiry" name="filter_insurance" domain="[('notification_type', '=', 'insurance_expiry')]"/>
                <filter string="License Expiry" name="filter_license" domain="[('notification_type', '=', 'license_expiry')]"/>
                <filter string="Maintenance Due" name="filter_maintenance" domain="[('notification_type', '=', 'maintenance_due')]"/>
                <filter string="Trip Delayed" name="filter_trip_delayed" domain="[('notification_type', '=', 'trip_delayed')]"/>
                <filter string="Fuel Budget Exceeded" name="filter_fuel_budget" domain="[('notification_type', '=', 'fuel_budget_exceeded')]"/>
                <group expand="0" string="Group By">
                    <filter string="Alert Type" name="group_type" context="{'group_by': 'notification_type'}"/>
                    <filter string="Severity" name="group_severity" context="{'group_by': 'severity'}"/>
                    <filter string="Read Status" name="group_read" context="{'group_by': 'is_read'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_transit_notification" model="ir.actions.act_window">
        <field name="name">Notifications</field>
        <field name="res_model">transit.notification</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_filter_unread': 1}</field>
        <field name="domain">[('user_id', '=', uid)]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No notifications yet.</p>
            <p>Alerts for insurance/license expiry, maintenance due, trip delays and fuel budget overruns will appear here.</p>
        </field>
    </record>

</odoo>
