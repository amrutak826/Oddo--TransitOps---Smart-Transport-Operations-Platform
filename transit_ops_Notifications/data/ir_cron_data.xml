<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="cron_check_insurance_expiry" model="ir.cron">
            <field name="name">TransitOps: Check Insurance Expiry</field>
            <field name="model_id" ref="model_transit_notification"/>
            <field name="state">code</field>
            <field name="code">model._cron_check_insurance_expiry()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
        </record>

