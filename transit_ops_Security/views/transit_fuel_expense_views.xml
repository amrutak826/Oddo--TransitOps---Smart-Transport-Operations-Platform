<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_transit_fuel_expense_list" model="ir.ui.view">
        <field name="name">transit.fuel.expense.list</field>
        <field name="model">transit.fuel.expense</field>
        <field name="arch" type="xml">
            <list string="Fuel &amp; Expense" sample="1">
                <field name="name"/>
                <field name="date"/>
                <field name="vehicle_id"/>
                <field name="driver_id"/>
                <field name="expense_type"/>
                <field name="amount" sum="Total Amount"/>
                <field name="state" widget="badge"
                       decoration-muted="state == 'draft'"
                       decoration-info="state == 'submitted'"
                       decoration-success="state == 'approved'"
                       decoration-danger="state == 'rejected'"/>
            </list>
        </field>
    </record>

    <record id="view_transit_fuel_expense_form" model="ir.ui.view">
        <field name="name">transit.fuel.expense.form</field>
        <field name="model">transit.fuel.expense</field>
        <field name="arch" type="xml">
            <form string="Fuel / Expense Record">
                <header>
                    <button name="action_submit" type="object" string="Submit"
                            class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_approve" type="object" string="Approve"
                            class="oe_highlight" invisible="state != 'submitted'"
                            groups="transit_ops.group_transit_financial_analyst,transit_ops.group_transit_fleet_manager"/>
                    <button name="action_reject" type="object" string="Reject"
                            invisible="state != 'submitted'"
                            groups="transit_ops.group_transit_financial_analyst,transit_ops.group_transit_fleet_manager"/>
                    <button name="action_reset_to_draft" type="object" string="Reset to Draft"
                            invisible="state != 'rejected'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,approved"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Record">
                            <field name="vehicle_id"/>
                            <field name="driver_id"/>
                            <field name="date"/>
                            <field name="expense_type"/>
                        </group>
                        <group string="Amount">
                            <field name="quantity_liters" invisible="expense_type != 'fuel'"/>
                            <field name="unit_price" invisible="expense_type != 'fuel'"/>
                            <field name="amount"/>
                            <field name="currency_id" groups="base.group_multi_currency"/>
                            <field name="odometer_reading"/>
                        </group>
                    </group>
                    <group invisible="state != 'rejected'">
                        <field name="rejection_reason" readonly="1"/>
                    </group>
                    <group string="Receipt">
                        <field name="receipt" filename="receipt_filename"/>
                        <field name="receipt_filename" invisible="1"/>
                    </group>
                    <notebook>
                        <page string="Notes" name="notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_transit_fuel_expense_search" model="ir.ui.view">
        <field name="name">transit.fuel.expense.search</field>
        <field name="model">transit.fuel.expense</field>
        <field name="arch" type="xml">
            <search string="Search Fuel &amp; Expense">
                <field name="name"/>
                <field name="vehicle_id"/>
                <field name="driver_id"/>
                <filter string="Draft" name="filter_draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Submitted" name="filter_submitted" domain="[('state', '=', 'submitted')]"/>
                <filter string="Approved" name="filter_approved" domain="[('state', '=', 'approved')]"/>
                <filter string="Rejected" name="filter_rejected" domain="[('state', '=', 'rejected')]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Expense Type" name="group_type" context="{'group_by': 'expense_type'}"/>
                    <filter string="Vehicle" name="group_vehicle" context="{'group_by': 'vehicle_id'}"/>
                    <filter string="Driver" name="group_driver" context="{'group_by': 'driver_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_transit_fuel_expense" model="ir.actions.act_window">
        <field name="name">Fuel &amp; Expense</field>
        <field name="res_model">transit.fuel.expense</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_transit_fuel_expense_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Log your first fuel or expense record</p>
            <p>Submit fuel, toll, repair and other costs for approval.</p>
        </field>
    </record>

</odoo>
