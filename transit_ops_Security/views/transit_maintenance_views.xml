<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_transit_maintenance_list" model="ir.ui.view">
        <field name="name">transit.maintenance.list</field>
        <field name="model">transit.maintenance</field>
        <field name="arch" type="xml">
            <list string="Maintenance" sample="1">
                <field name="name"/>
                <field name="vehicle_id"/>
                <field name="maintenance_type"/>
                <field name="scheduled_date"/>
                <field name="vendor"/>
                <field name="cost" sum="Total Cost"/>
                <field name="state" widget="badge"
                       decoration-muted="state in ('draft', 'cancelled')"
                       decoration-info="state == 'scheduled'"
                       decoration-warning="state == 'in_progress'"
                       decoration-success="state == 'completed'"/>
            </list>
        </field>
    </record>

    <record id="view_transit_maintenance_form" model="ir.ui.view">
        <field name="name">transit.maintenance.form</field>
        <field name="model">transit.maintenance</field>
        <field name="arch" type="xml">
            <form string="Maintenance">
                <header>
                    <button name="action_schedule" type="object" string="Schedule"
                            class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_start" type="object" string="Start"
                            class="oe_highlight" invisible="state != 'scheduled'"/>
                    <button name="action_complete" type="object" string="Complete"
                            class="oe_highlight" invisible="state != 'in_progress'"/>
                    <button name="action_cancel" type="object" string="Cancel"
                            invisible="state in ('completed', 'cancelled')"
                            confirm="Are you sure you want to cancel this maintenance record?"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,scheduled,in_progress,completed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Vehicle">
                            <field name="vehicle_id"/>
                            <field name="maintenance_type"/>
                            <field name="odometer_reading"/>
                        </group>
                        <group string="Schedule">
                            <field name="scheduled_date"/>
                            <field name="completion_date" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <group string="Vendor &amp; Cost">
                            <field name="vendor"/>
                            <field name="cost"/>
                        </group>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1"/>
                    </group>
                    <notebook>
                        <page string="Notes" name="notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_transit_maintenance_search" model="ir.ui.view">
        <field name="name">transit.maintenance.search</field>
        <field name="model">transit.maintenance</field>
        <field name="arch" type="xml">
            <search string="Search Maintenance">
                <field name="name"/>
                <field name="vehicle_id"/>
                <field name="vendor"/>
                <filter string="Scheduled" name="filter_scheduled" domain="[('state', '=', 'scheduled')]"/>
                <filter string="In Progress" name="filter_in_progress" domain="[('state', '=', 'in_progress')]"/>
                <filter string="Completed" name="filter_completed" domain="[('state', '=', 'completed')]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Type" name="group_type" context="{'group_by': 'maintenance_type'}"/>
                    <filter string="Vehicle" name="group_vehicle" context="{'group_by': 'vehicle_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_transit_maintenance" model="ir.actions.act_window">
        <field name="name">Maintenance</field>
        <field name="res_model">transit.maintenance</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_transit_maintenance_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Log your first maintenance record</p>
            <p>Track preventive, corrective and inspection work across the fleet.</p>
        </field>
    </record>

</odoo>
