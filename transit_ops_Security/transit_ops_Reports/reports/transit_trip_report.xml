<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_report_transit_trip" model="ir.actions.report">
        <field name="name">Trip Report</field>
        <field name="model">transit.trip</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">transit_ops.report_transit_trip_document</field>
        <field name="report_file">transit_ops.report_transit_trip_document</field>
        <field name="print_report_name">'Trip Report - %s' % (object.name)</field>
        <field name="binding_model_id" ref="model_transit_trip"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_transit_trip_document">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="transit_report_wrap page">
                    <t t-call="transit_ops.report_transit_styles"/>
                    <t t-call="transit_ops.report_transit_banner">
                        <t t-set="title">Trip Report</t>
                        <t t-set="subtitle">Trip dispatch log with routes and schedules</t>
                    </t>

                    <table class="transit_report_table">
                        <thead>
                            <tr>
                                <th>Reference</th>
                                <th>Vehicle</th>
                                <th>Driver</th>
                                <th>Origin</th>
                                <th>Destination</th>
                                <th>Scheduled Start</th>
                                <th>Distance</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="docs" t-as="trip">
                                <td><t t-esc="trip.name"/></td>
                                <td><t t-esc="trip.vehicle_id.name"/></td>
                                <td><t t-esc="trip.driver_id.name"/></td>
                                <td><t t-esc="trip.origin"/></td>
                                <td><t t-esc="trip.destination"/></td>
                                <td><t t-esc="trip.scheduled_start"/></td>
                                <td><t t-esc="'%.1f km' % trip.distance_km"/></td>
                                <td>
                                    <span t-attf-class="transit_badge {{ 'transit_badge_success' if trip.state == 'completed' else ('transit_badge_info' if trip.state in ('scheduled', 'in_progress') else '') }}">
                                        <t t-esc="dict(trip._fields['state'].selection).get(trip.state, '')"/>
                                    </span>
                                </td>
                            </tr>
                        </tbody>
                    </table>

                    <div class="transit_report_summary">
                        Total Trips: <strong><t t-esc="len(docs)"/></strong>
                        &#160;|&#160; Completed: <strong><t t-esc="len(docs.filtered(lambda t: t.state == 'completed'))"/></strong>
                        &#160;|&#160; Total Distance: <strong><t t-esc="'%.1f km' % sum(docs.mapped('distance_km'))"/></strong>
                    </div>
                </div>
            </t>
        </t>
    </template>

</odoo>
