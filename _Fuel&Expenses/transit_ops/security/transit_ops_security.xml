<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- ============================================================
             MODULE CATEGORY
        ============================================================= -->
        <record id="module_category_transit_ops" model="ir.module.category">
            <field name="name">TransitOps</field>
            <field name="description">Smart Transport Operations Platform access levels</field>
            <field name="sequence">20</field>
        </record>

        <!-- ============================================================
             GROUPS (Role Based Security)
             Hierarchy: Admin > Fleet Manager > Dispatcher > Viewer
        ============================================================= -->

        <!-- 1. Viewer: read-only access to everything -->
        <record id="group_transit_viewer" model="res.groups">
            <field name="name">Viewer</field>
            <field name="category_id" ref="module_category_transit_ops"/>
            <field name="comment">Read-only access to vehicles, drivers, trips, maintenance and reports.</field>
        </record>

        <!-- 2. Dispatcher: manages trips/dispatch, views fleet & drivers -->
        <record id="group_transit_dispatcher" model="res.groups">
            <field name="name">Dispatcher</field>
            <field name="category_id" ref="module_category_transit_ops"/>
            <field name="implied_ids" eval="[(4, ref('group_transit_viewer'))]"/>
            <field name="comment">Can create and manage trips, assign vehicles and drivers.</field>
        </record>

        <!-- 3. Fleet Manager: full control over vehicles, drivers, maintenance, fuel -->
        <record id="group_transit_manager" model="res.groups">
            <field name="name">Fleet Manager</field>
            <field name="category_id" ref="module_category_transit_ops"/>
            <field name="implied_ids" eval="[(4, ref('group_transit_dispatcher'))]"/>
            <field name="comment">Full control over vehicle registry, driver records, maintenance and fuel/expense data.</field>
        </record>

        <!-- 4. Administrator: full system control incl. security/config -->
        <record id="group_transit_admin" model="res.groups">
            <field name="name">Administrator</field>
            <field name="category_id" ref="module_category_transit_ops"/>
            <field name="implied_ids" eval="[(4, ref('group_transit_manager'))]"/>
            <field name="comment">Full administrative access including configuration and security settings.</field>
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
        </record>

        <!-- ============================================================
             MULTI-COMPANY RECORD RULES
        ============================================================= -->
        <record id="rule_transit_vehicle_company" model="ir.rule">
            <field name="name">Transit Vehicle: multi-company</field>
            <field name="model_id" ref="model_transit_vehicle"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('group_transit_viewer'))]"/>
        </record>

        <record id="rule_transit_driver_company" model="ir.rule">
            <field name="name">Transit Driver: multi-company</field>
            <field name="model_id" ref="model_transit_driver"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('group_transit_viewer'))]"/>
        </record>

    </data>
</odoo>
