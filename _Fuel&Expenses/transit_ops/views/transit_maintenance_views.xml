<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ================= LIST VIEW ================= -->
        <record id="view_transit_maintenance_list" model="ir.ui.view">
            <field name="name">transit.maintenance.list</field>
            <field name="model">transit.maintenance</field>
            <field name="arch" type="xml">
                <list string="Maintenance Records"
                      decoration-danger="is_overdue"
                      decoration-success="status == 'completed'"
                      decoration-muted="status == 'cancelled'"
                      decoration-info="status == 'in_progress'">
                    <field name="vehicle_id"/>
                    <field name="maintenance_type"/>
                    <field name="scheduled_date"/>
                    <field name="completed_date" optional="show"/>
                    <field name="mechanic_id" optional="show"/>
                    <field name="estimated_cost" sum="Total Estimated" optional="show"/>
                    <field name="actual_cost" sum="Total Actual" optional="show"/>
                    <field name="is_overdue" widget="boolean_toggle" optional="hide"/>
                    <field name="status" widget="badge"
                           decoration-success="status == 'completed'"
                           decoration-info="status == 'in_progress'"
                           decoration-warning="status == 'scheduled'"
                           decoration-muted="status == 'cancelled'"/>
                </list>
            </field>
        </record>

        <!-- ================= FORM VIEW ================= -->
        <record id="view_transit_maintenance_form" model="ir.ui.view">
            <field name="name">transit.maintenance.form</field>
            <field name="model">transit.maintenance</field>
            <field name="arch" type="xml">
                <form string="Maintenance Record">
                    <header>
                        <button name="action_schedule" type="object" string="Schedule"
                                class="oe_highlight" invisible="status != 'draft'"/>
                        <button name="action_start" type="object" string="Start Maintenance"
                                class="oe_highlight" invisible="status not in ('draft', 'scheduled')"/>
                        <button name="action_complete" type="object" string="Mark Completed"
                                class="oe_highlight" invisible="status != 'in_progress'"/>
                        <button name="action_cancel" type="object" string="Cancel"
                                invisible="status in ('completed', 'cancelled')"
                                confirm="Are you sure you want to cancel this maintenance record?"/>
                        <button name="action_reset_to_draft" type="object" string="Reset to Draft"
                                invisible="status == 'draft'"/>
                        <field name="status" widget="statusbar"
                               statusbar_visible="draft,scheduled,in_progress,completed"/>
                    </header>
                    <sheet>
                        <widget name="web_ribbon" title="Overdue" bg_color="text-bg-danger"
                                invisible="not is_overdue"/>
                        <widget name="web_ribbon" title="Cancelled" bg_color="text-bg-danger"
                                invisible="status != 'cancelled'"/>
                        <div class="oe_title">
                            <h1>
                                <field name="vehicle_id" placeholder="Select Vehicle..." options="{'no_create': True}"/>
                            </h1>
                        </div>
                        <group>
                            <group string="Maintenance Details">
                                <field name="maintenance_type"/>
                                <field name="mechanic_id" options="{'no_quick_create': True}"/>
                                <field name="description"/>
                            </group>
                            <group string="Schedule">
                                <field name="scheduled_date"/>
                                <field name="completed_date"/>
                                <field name="is_overdue" invisible="1"/>
                                <field name="days_until_due"
                                       invisible="status not in ('draft', 'scheduled', 'in_progress')"/>
                            </group>
                        </group>
                        <group>
                            <group string="Cost">
                                <field name="currency_id" invisible="1"/>
                                <field name="estimated_cost"/>
                                <field name="actual_cost"/>
                            </group>
                            <group string="Tracking" groups="base.group_no_one">
                                <field name="reminder_sent" readonly="1"/>
                                <field name="overdue_notified" readonly="1"/>
                                <field name="company_id" groups="base.group_multi_company"/>
                            </group>
                        </group>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- ================= SEARCH VIEW ================= -->
        <record id="view_transit_maintenance_search" model="ir.ui.view">
            <field name="name">transit.maintenance.search</field>
            <field name="model">transit.maintenance</field>
            <field name="arch" type="xml">
                <search string="Search Maintenance">
                    <field name="vehicle_id"/>
                    <field name="mechanic_id"/>
                    <field name="maintenance_type"/>
                    <field name="description"/>
                    <filter string="Overdue" name="filter_overdue" domain="[('is_overdue', '=', True)]"/>
                    <filter string="Due This Week" name="filter_due_week"
                            domain="[('days_until_due', '&gt;=', 0), ('days_until_due', '&lt;=', 7),
                                     ('status', 'in', ('draft', 'scheduled', 'in_progress'))]"/>
                    <separator/>
                    <filter string="Draft" name="filter_draft" domain="[('status', '=', 'draft')]"/>
                    <filter string="Scheduled" name="filter_scheduled" domain="[('status', '=', 'scheduled')]"/>
                    <filter string="In Progress" name="filter_in_progress" domain="[('status', '=', 'in_progress')]"/>
                    <filter string="Completed" name="filter_completed" domain="[('status', '=', 'completed')]"/>
                    <filter string="Cancelled" name="filter_cancelled" domain="[('status', '=', 'cancelled')]"/>
                    <separator/>
                    <filter string="Scheduled Date" name="filter_scheduled_date" date="scheduled_date"/>
                    <group expand="0" string="Group By">
                        <filter string="Vehicle" name="group_vehicle" context="{'group_by': 'vehicle_id'}"/>
                        <filter string="Status" name="group_status" context="{'group_by': 'status'}"/>
                        <filter string="Maintenance Type" name="group_type" context="{'group_by': 'maintenance_type'}"/>
                        <filter string="Mechanic / Workshop" name="group_mechanic" context="{'group_by': 'mechanic_id'}"/>
                        <filter string="Scheduled Date" name="group_scheduled_date" context="{'group_by': 'scheduled_date'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- ================= ACTION ================= -->
        <record id="action_transit_maintenance" model="ir.actions.act_window">
            <field name="name">Maintenance</field>
            <field name="res_model">transit.maintenance</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_transit_maintenance_search"/>
            <field name="context">{'search_default_filter_overdue': 0}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Schedule your first maintenance record
                </p>
                <p>
                    Track preventive and corrective maintenance for your fleet.
                    Vehicles are automatically marked unavailable while maintenance is in progress.
                </p>
            </field>
        </record>

        <!-- Convenience action: Overdue Maintenance -->
        <record id="action_transit_maintenance_overdue" model="ir.actions.act_window">
            <field name="name">Overdue Maintenance</field>
            <field name="res_model">transit.maintenance</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_transit_maintenance_search"/>
            <field name="domain">[('is_overdue', '=', True)]</field>
            <field name="context">{}</field>
        </record>

    </data>
</odoo>
