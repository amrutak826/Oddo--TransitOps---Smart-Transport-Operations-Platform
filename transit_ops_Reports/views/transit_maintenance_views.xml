<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================= List View ================= -->
    <record id="view_transit_maintenance_list" model="ir.ui.view">
        <field name="name">transit.maintenance.list</field>
        <field name="model">transit.maintenance</field>
        <field name="arch" type="xml">
            <list string="Maintenance" decoration-warning="state=='due'"
                  decoration-info="state=='in_progress'"
                  decoration-success="state=='completed'"
                  decoration-muted="state=='cancelled'">
                <field name="name"/>
                <field name="vehicle_id"/>
                <field name="maintenance_type"/>
                <field name="description"/>
                <field name="scheduled_date"/>
                <field name="vendor"/>
                <field name="cost" sum="Total Cost"/>
                <field name="state" widget="badge"
                       decoration-warning="state=='due'"
                       decoration-info="state=='in_progress'"
                       decoration-success="state=='completed'"
                       decoration-muted="state=='cancelled'"/>
            </list>
        </field>
    </record>

    <!-- ================= Form View ================= -->
    <record id="view_transit_maintenance_form" model="ir.ui.view">
        <field name="name">transit.maintenance.form</field>
        <field name="model">transit.maintenance</field>
        <field name="arch" type="xml">
            <form string="Maintenance">
                <header>
                    <button name="action_start" type="object" string="Start" class="btn-primary" invisible="state != 'due'"/>
                    <button name="action_complete" type="object" string="Mark Completed" class="btn-primary" invisible="state != 'in_progress'"/>
                    <button name="action_cancel" type="object" string="Cancel" invisible="state in ('completed', 'cancelled')"/>
                    <field name="state" widget="statusbar" statusbar_visible="due,in_progress,completed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Service Details">
                            <field name="vehicle_id"/>
                            <field name="maintenance_type"/>
                            <field name="description"/>
                            <field name="vendor"/>
                        </group>
                        <group string="Schedule &amp; Cost">
                            <field name="scheduled_date"/>
                            <field name="completed_date"/>
                            <field name="odometer_reading"/>
                            <field name="cost"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes">
                            <field name="notes" placeholder="Service notes..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ================= Search View ================= -->
    <record id="view_transit_maintenance_search" model="ir.ui.view">
        <field name="name">transit.maintenance.search</field>
        <field name="model">transit.maintenance</field>
        <field name="arch" type="xml">
            <search string="Search Maintenance">
                <field name="name" string="Reference" filter_domain="['|', ('name', 'ilike', self), ('description', 'ilike', self)]"/>
                <field name="vehicle_id"/>
                <field name="vendor"/>
                <filter string="Due" name="filter_due" domain="[('state', '=', 'due')]"/>
                <filter string="In Progress" name="filter_in_progress" domain="[('state', '=', 'in_progress')]"/>
                <filter string="Completed" name="filter_completed" domain="[('state', '=', 'completed')]"/>
                <filter string="Cancelled" name="filter_cancelled" domain="[('state', '=', 'cancelled')]"/>
                <separator/>
                <filter string="Preventive" name="filter_preventive" domain="[('maintenance_type', '=', 'preventive')]"/>
                <filter string="Corrective" name="filter_corrective" domain="[('maintenance_type', '=', 'corrective')]"/>
                <separator/>
                <filter string="Scheduled Date" name="filter_date" date="scheduled_date"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Type" name="group_type" context="{'group_by': 'maintenance_type'}"/>
                    <filter string="Vehicle" name="group_vehicle" context="{'group_by': 'vehicle_id'}"/>
                    <filter string="Scheduled Date (Month)" name="group_month" context="{'group_by': 'scheduled_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ================= Action ================= -->
    <record id="action_transit_maintenance" model="ir.actions.act_window">
        <field name="name">Maintenance</field>
        <field name="res_model">transit.maintenance</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_transit_maintenance_search"/>
        <field name="context">{'search_default_filter_due': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Schedule your first maintenance record
            </p>
            <p>
                Track preventive and corrective maintenance across your fleet.
            </p>
        </field>
    </record>

</odoo>
