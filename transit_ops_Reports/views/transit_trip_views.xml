<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================= List View ================= -->
    <record id="view_transit_trip_list" model="ir.ui.view">
        <field name="name">transit.trip.list</field>
        <field name="model">transit.trip</field>
        <field name="arch" type="xml">
            <list string="Trips" decoration-info="state=='in_progress'"
                  decoration-success="state=='completed'"
                  decoration-muted="state=='cancelled'">
                <field name="name"/>
                <field name="vehicle_id"/>
                <field name="driver_id"/>
                <field name="origin"/>
                <field name="destination"/>
                <field name="scheduled_start"/>
                <field name="distance_km" sum="Total Distance"/>
                <field name="priority" widget="priority"/>
                <field name="state" widget="badge"
                       decoration-secondary="state=='draft'"
                       decoration-info="state=='scheduled'"
                       decoration-primary="state=='in_progress'"
                       decoration-success="state=='completed'"
                       decoration-muted="state=='cancelled'"/>
            </list>
        </field>
    </record>

    <!-- ================= Form View ================= -->
    <record id="view_transit_trip_form" model="ir.ui.view">
        <field name="name">transit.trip.form</field>
        <field name="model">transit.trip</field>
        <field name="arch" type="xml">
            <form string="Trip">
                <header>
                    <button name="action_confirm" type="object" string="Confirm" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_start" type="object" string="Start Trip" class="btn-primary" invisible="state != 'scheduled'"/>
                    <button name="action_complete" type="object" string="Complete" class="btn-primary" invisible="state != 'in_progress'"/>
                    <button name="action_cancel" type="object" string="Cancel" invisible="state in ('completed', 'cancelled')"/>
                    <button name="action_reset_draft" type="object" string="Reset to Draft" invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,scheduled,in_progress,completed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Assignment">
                            <field name="vehicle_id"/>
                            <field name="driver_id"/>
                            <field name="priority" widget="priority"/>
                        </group>
                        <group string="Route">
                            <field name="origin"/>
                            <field name="destination"/>
                            <field name="distance_km"/>
                            <field name="passenger_count"/>
                        </group>
                    </group>
                    <group>
                        <group string="Schedule">
                            <field name="scheduled_start"/>
                            <field name="scheduled_end"/>
                        </group>
                        <group string="Actual">
                            <field name="actual_start"/>
                            <field name="actual_end"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes">
                            <field name="notes" placeholder="Trip notes..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ================= Search View ================= -->
    <record id="view_transit_trip_search" model="ir.ui.view">
        <field name="name">transit.trip.search</field>
        <field name="model">transit.trip</field>
        <field name="arch" type="xml">
            <search string="Search Trips">
                <field name="name" string="Trip" filter_domain="['|', '|', ('name', 'ilike', self), ('origin', 'ilike', self), ('destination', 'ilike', self)]"/>
                <field name="vehicle_id"/>
                <field name="driver_id"/>
                <filter string="Today" name="filter_today" domain="[('scheduled_start', '&gt;=', context_today().strftime('%Y-%m-%d 00:00:00')), ('scheduled_start', '&lt;=', context_today().strftime('%Y-%m-%d 23:59:59'))]"/>
                <filter string="Draft" name="filter_draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Scheduled" name="filter_scheduled" domain="[('state', '=', 'scheduled')]"/>
                <filter string="In Progress" name="filter_in_progress" domain="[('state', '=', 'in_progress')]"/>
                <filter string="Completed" name="filter_completed" domain="[('state', '=', 'completed')]"/>
                <filter string="Cancelled" name="filter_cancelled" domain="[('state', '=', 'cancelled')]"/>
                <separator/>
                <filter string="Scheduled Start" name="filter_date" date="scheduled_start"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Vehicle" name="group_vehicle" context="{'group_by': 'vehicle_id'}"/>
                    <filter string="Driver" name="group_driver" context="{'group_by': 'driver_id'}"/>
                    <filter string="Scheduled Start (Month)" name="group_month" context="{'group_by': 'scheduled_start:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ================= Action ================= -->
    <record id="action_transit_trip" model="ir.actions.act_window">
        <field name="name">Trips</field>
        <field name="res_model">transit.trip</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_transit_trip_search"/>
        <field name="context">{'search_default_filter_today': 0}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Dispatch your first trip
            </p>
            <p>
                Plan, assign and track trips across your fleet in real time.
            </p>
        </field>
    </record>

</odoo>
