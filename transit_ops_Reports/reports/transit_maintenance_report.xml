<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_report_transit_maintenance" model="ir.actions.report">
        <field name="name">Maintenance Report</field>
        <field name="model">transit.maintenance</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">transit_ops.report_transit_maintenance_document</field>
        <field name="report_file">transit_ops.report_transit_maintenance_document</field>
        <field name="print_report_name">'Maintenance Report - %s' % (object.name)</field>
        <field name="binding_model_id" ref="model_transit_maintenance"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_transit_maintenance_document">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="transit_report_wrap page">
                    <t t-call="transit_ops.report_transit_styles"/>
                    <t t-call="transit_ops.report_transit_banner">
                        <t t-set="title">Maintenance Report</t>
                        <t t-set="subtitle">Preventive and corrective service history</t>
                    </t>

                    <table class="transit_report_table">
                        <thead>
                            <tr>
                                <th>Reference</th>
                                <th>Vehicle</th>
                                <th>Type</th>
                                <th>Description</th>
                                <th>Scheduled Date</th>
                                <th>Vendor</th>
                                <th>Cost</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="docs" t-as="rec">
                                <td><t t-esc="rec.name"/></td>
                                <td><t t-esc="rec.vehicle_id.name"/></td>
                                <td><t t-esc="dict(rec._fields['maintenance_type'].selection).get(rec.maintenance_type, '')"/></td>
                                <td><t t-esc="rec.description"/></td>
                                <td><t t-esc="rec.scheduled_date"/></td>
                                <td><t t-esc="rec.vendor or '-'"/></td>
                                <td><t t-esc="'%.2f' % rec.cost"/></td>
                                <td>
                                    <span t-attf-class="transit_badge {{ 'transit_badge_success' if rec.state == 'completed' else ('transit_badge_warning' if rec.state == 'due' else ('transit_badge_info' if rec.state == 'in_progress' else '')) }}">
                                        <t t-esc="dict(rec._fields['state'].selection).get(rec.state, '')"/>
                                    </span>
                                </td>
                            </tr>
                        </tbody>
                    </table>

                    <div class="transit_report_summary">
                        Total Records: <strong><t t-esc="len(docs)"/></strong>
                        &#160;|&#160; Due: <strong><t t-esc="len(docs.filtered(lambda m: m.state == 'due'))"/></strong>
                        &#160;|&#160; Total Cost: <strong><t t-esc="'%.2f' % sum(docs.mapped('cost'))"/></strong>
                    </div>
                </div>
            </t>
        </t>
    </template>

</odoo>
