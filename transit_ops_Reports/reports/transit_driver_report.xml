<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_report_transit_driver" model="ir.actions.report">
        <field name="name">Driver Report</field>
        <field name="model">transit.driver</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">transit_ops.report_transit_driver_document</field>
        <field name="report_file">transit_ops.report_transit_driver_document</field>
        <field name="print_report_name">'Driver Report - %s' % (object.name)</field>
        <field name="binding_model_id" ref="model_transit_driver"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_transit_driver_document">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="transit_report_wrap page">
                    <t t-call="transit_ops.report_transit_styles"/>
                    <t t-call="transit_ops.report_transit_banner">
                        <t t-set="title">Driver Report</t>
                        <t t-set="subtitle">Driver roster, licenses and trip activity</t>
                    </t>

                    <table class="transit_report_table">
                        <thead>
                            <tr>
                                <th>Code</th>
                                <th>Name</th>
                                <th>License No.</th>
                                <th>Type</th>
                                <th>License Expiry</th>
                                <th>Experience</th>
                                <th>Trips</th>
                                <th>License Status</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="docs" t-as="driver">
                                <td><t t-esc="driver.sequence_code"/></td>
                                <td><t t-esc="driver.name"/></td>
                                <td><t t-esc="driver.license_number"/></td>
                                <td><t t-esc="dict(driver._fields['license_type'].selection).get(driver.license_type, '')"/></td>
                                <td><t t-esc="driver.license_expiry"/></td>
                                <td><t t-esc="driver.experience_years"/> yrs</td>
                                <td><t t-esc="driver.trip_count"/></td>
                                <td>
                                    <span t-attf-class="transit_badge {{ 'transit_badge_success' if driver.license_status == 'valid' else ('transit_badge_warning' if driver.license_status == 'expiring_soon' else 'transit_badge_danger') }}">
                                        <t t-esc="dict(driver._fields['license_status'].selection).get(driver.license_status, '')"/>
                                    </span>
                                </td>
                                <td>
                                    <span t-attf-class="transit_badge {{ 'transit_badge_success' if driver.state == 'available' else ('transit_badge_info' if driver.state == 'on_trip' else '') }}">
                                        <t t-esc="dict(driver._fields['state'].selection).get(driver.state, '')"/>
                                    </span>
                                </td>
                            </tr>
                        </tbody>
                    </table>

                    <div class="transit_report_summary">
                        Total Drivers: <strong><t t-esc="len(docs)"/></strong>
                        &#160;|&#160; Available: <strong><t t-esc="len(docs.filtered(lambda d: d.state == 'available'))"/></strong>
                        &#160;|&#160; Licenses Expiring / Expired: <strong><t t-esc="len(docs.filtered(lambda d: d.license_status != 'valid'))"/></strong>
                    </div>
                </div>
            </t>
        </t>
    </template>

</odoo>
